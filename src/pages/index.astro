    description: 'Pengasuhan, peran ayah, dan pertumbuhan muslimah.',
    links: [
      ['IAPA', '/iapa/'],
      ['The Father Project', '/program/the-father-project/'],
      ['The Fitrah Journey', '/program/the-fitrah-journey/'],
    ],
  },
  {
    title: 'Anak dan Al-Qur\'an',
    description: 'Belajar dari rumah dan menyiapkan guru Al-Qur\'an.',
    links: [
