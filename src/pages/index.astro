    summary: 'Belajar memahami anak, menata respons, dan membangun pengasuhan Islami yang bertahap.',
    image: '/images/iapa-parenting-home-hero.png',
    href: '/iapa/',
    className: 'hm-program-card--wide',
  },
  {
    name: 'IAIS Home-Based Learning',
    audience: 'Anak dan keluarga',
    summary: 'Sekolah Islam berbasis keluarga dengan target yang jelas dan ritme belajar yang fleksibel.',
    image: '/images/iais-home-learning-hero.png',
    href: '/program/homebased-learning/',
    className: 'hm-program-card--tall',
  },
  {
    name: 'The Fitrah Journey',
    audience: 'Muslimah dewasa',
    summary: 'Ruang belajar untuk menata iman, peran, dan pertumbuhan diri sesuai fitrah.',
    image: '/images/fitrah-journey-muslimah-hero.png',
    href: '/program/the-fitrah-journey/',
  },
  {
    name: 'PKGQ PAUD & SD',
    audience: 'Calon guru Al-Qur\'an',
    summary: 'Kaderisasi pendidik anak usia dini dan sekolah dasar yang berilmu dan beradab.',
    image: '/images/pkgq-teacher-training-hero.png',
    href: '/program/kaderisasi-guru-quran-paud-sd/',
  },
  {
    name: 'IAIEE',
    audience: 'Lembaga pendidikan Islam',
    summary: 'Pendampingan mutu SDM, kurikulum, sistem, dan tata kelola lembaga.',
    image: '/images/iaiee-quality-assurance-hero.png',
    href: '/program/iaiee/',
