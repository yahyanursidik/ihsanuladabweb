    body: 'Bawa ilmu menjadi kebiasaan, adab, dan perbaikan yang dapat dijaga di rumah, kelas, komunitas, atau lembaga.',
  },
];

const learningMap = [
  {
    number: '01',
    title: 'Keluarga',
    need: 'Pengasuhan, peran ayah, dan pertumbuhan muslimah.',
    programs: 'IAPA · Father Project · Fitrah Journey',
    href: '/iapa/',
  },
  {
    number: '02',
    title: 'Anak dan Al-Qur\'an',
    need: 'Ritme belajar dari rumah dan kaderisasi guru Al-Qur\'an.',
    programs: 'IAIS HBL · PKGQ PAUD & SD',
    href: '/program/homebased-learning/',
