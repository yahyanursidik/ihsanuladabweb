---

<BaseLayout
  title="Yayasan Pendidikan Ihsanul Adab"
  description="Temukan jalur pendidikan Islam untuk orang tua, anak, remaja, guru, dan lembaga yang berakar pada tauhid, adab, ilmu, dan amal."
>
  <div class="hm-home">
    <a class="hm-skip" href="#konten">Lewati ke konten utama</a>

    <header class="hm-masthead">
      <div class="hm-masthead__utility">
        <span>Ekosistem pendidikan Islam untuk keluarga, pendidik, dan lembaga</span>
        <a href={consultationUrl}>Konsultasi program</a>
      </div>

      <div class="hm-masthead__brand-row">
        <a class="hm-brand" href="/" aria-label="Beranda Yayasan Pendidikan Ihsanul Adab">
          <img src="/images/logo-ihsanul-adab.png" alt="" width="54" height="54" />
          <span>
            <strong>Yayasan Pendidikan Ihsanul Adab</strong>
          </span>
        </a>
      </div>

      <div class="hm-nav-row">
        <nav class="hm-desktop-nav" aria-label="Navigasi utama">
          <a href="/tentang-kami/">Tentang kami</a>
          <details class="hm-program-menu">
            <summary>Program</summary>
            <div class="hm-program-menu__panel">
              {programMenuItems.map(([label, note, href]) => (
                <a href={href}>
                  <strong>{label}</strong>
                  <span>{note}</span>
                </a>
              ))}
            </div>
          </details>
          <a href="#jalur">Jalur belajar</a>
          <a href="#cara-belajar">Cara belajar</a>
          <a href="/karir-pengabdian/">Karir &amp; pengabdian</a>
        </nav>
        <a class="hm-lms-link" href={lmsUrl}>Akses LMS</a>

        <details class="hm-mobile-menu">
          <summary>Menu</summary>
          <nav aria-label="Navigasi seluler">
            <a href="/tentang-kami/">Tentang kami</a>
            <a href="#jalur">Jalur belajar</a>
            <a href="#program">Semua program</a>
            <a href="#cara-belajar">Cara belajar</a>
            <a href="/karir-pengabdian/">Karir &amp; pengabdian</a>
            <a href={lmsUrl}>Akses LMS</a>
            <a href={consultationUrl}>Konsultasi program</a>
          </nav>
        </details>
      </div>
    </header>

    <main id="konten">
      <section class="hm-hero" aria-labelledby="hero-title">
        <div class="hm-hero__copy">
          <p class="hm-hero__lead">Tauhid · Adab · Ilmu · Amal</p>
          <h1 id="hero-title">Pendidikan Islam untuk setiap peran.</h1>
          <p>
            Ihsanul Adab membantu keluarga, remaja, pendidik, dan lembaga menemukan jalan
            belajar yang sesuai, lalu membawa ilmunya ke dalam kehidupan sehari-hari.
          </p>
          <div class="hm-actions">
            <a class="hm-button hm-button--primary" href="#jalur">
              <span class="hm-label-long">Temukan jalur Anda</span>
              <span class="hm-label-short">Pilih jalur</span>
            </a>
            <a class="hm-button hm-button--quiet" href={consultationUrl}>
              <span class="hm-label-long">Konsultasi program</span>
              <span class="hm-label-short">Konsultasi</span>
            </a>
          </div>
        </div>
        <figure class="hm-hero__figure">
          <img
            src="/images/home-hero-garden-learning.png"
            alt="Meja belajar dengan kitab tertutup, kartu peta belajar, kompas, lentera, dan pola geometri Islami tanpa figur makhluk bernyawa"
            width="1536"
            height="1024"
            fetchpriority="high"
          />
          <figcaption>Belajar dari fondasi, tumbuh dalam adab, dan bergerak menuju amal.</figcaption>
        </figure>
      </section>

      <section class="hm-role-section" id="jalur" aria-labelledby="role-title">
        <header class="hm-section-intro">
          <h2 id="role-title">Mulai dari peran Anda hari ini.</h2>
          <p>Pilih kebutuhan yang paling dekat. Setiap jalur membawa Anda langsung ke program yang relevan.</p>
        </header>
        <div class="hm-role-index">
          {audiencePaths.map((path) => (
            <a class="hm-role-link" href={path.href}>
              <strong>{path.role}</strong>
              <span>{path.need}</span>
              <small>{path.program}</small>
              <span class="hm-arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </section>

      <section class="hm-learning-map" id="peta-belajar" aria-labelledby="learning-map-title">
        <header class="hm-section-intro">
          <h2 id="learning-map-title">Temukan jalan belajar tanpa menebak-nebak.</h2>
          <p>Mulai dari kebutuhan yang nyata, pilih rumpun yang paling dekat, lalu masuk ke program dengan arah belajar yang jelas.</p>
        </header>

        <figure class="hm-learning-map__figure" data-flow-reveal>
          <div class="hm-flow-start">
            <span>Mulai di sini</span>
            <strong>Kebutuhan hari ini</strong>
            <small>Peran · usia · tantangan</small>
          </div>

          <ol class="hm-flow-paths">
            {learningMap.map((path) => (
              <li class="hm-flow-node">
                <a href={path.href} aria-label={`Jelajahi jalur ${path.title}`}>
                  <span>{path.number}</span>
                  <h3>{path.title}</h3>
                  <p>{path.need}</p>
                  <small>{path.programs}</small>
                </a>
              </li>
            ))}
          </ol>

          <div class="hm-flow-outcome">
            <span>Arah yang dijaga</span>
            <strong>Ilmu dipahami, diamalkan, lalu dirawat.</strong>
          </div>
          <figcaption>Peta jalur belajar Ihsanul Adab dari kebutuhan menuju pembelajaran yang berbuah amal.</figcaption>
        </figure>
      </section>

      <section class="hm-featured" id="program" aria-labelledby="featured-title">
        <header class="hm-section-intro hm-section-intro--wide">
          <div>
            <h2 id="featured-title">Program yang paling sering menjadi pintu masuk.</h2>
            <p>Setiap program memiliki tujuan, peserta, dan ritme belajar yang berbeda.</p>
          </div>
          <a class="hm-text-link" href={consultationUrl}>Belum yakin? Tanya tim kami</a>
        </header>

        <div class="hm-program-mosaic">
          {featuredPrograms.map((program) => (
            <article class:list={['hm-program-card', program.className]}>
              <a href={program.href} aria-label={`Lihat ${program.name}`}>
                <img
                  src={program.image}
                  alt=""
                  width="1536"
                  height="1024"
                  loading="lazy"
                />
                <div>
                  <small>{program.audience}</small>
                  <h3>{program.name}</h3>
                  <p>{program.summary}</p>
                  <span>Lihat program <span aria-hidden="true">↗</span></span>
                </div>
              </a>
            </article>
          ))}
        </div>

        <div class="hm-program-index" aria-label="Seluruh kelompok program">
          {programCollections.map((collection) => (
            <section>
              <h3>{collection.title}</h3>
              <p>{collection.description}</p>
              <ul>
                {collection.links.map(([label, href]) => (
                  <li><a class="hm-program-link" href={href}>{label}<span aria-hidden="true">→</span></a></li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </section>

      <section class="hm-workflow" id="cara-belajar" aria-labelledby="workflow-title">
        <header class="hm-section-intro">
          <h2 id="workflow-title">Ilmu dijaga melalui proses.</h2>
          <p>Belajar tidak berhenti pada menyelesaikan materi. Prosesnya dirancang agar perubahan dapat dipahami, dicoba, lalu dijaga.</p>
        </header>
        <ol class="hm-steps">
          {learningStages.map((stage) => (
            <li>
              <span>{stage.number}</span>
              <h3>{stage.title}</h3>
              <p>{stage.body}</p>
            </li>
          ))}
        </ol>
      </section>

      <section class="hm-principles" aria-labelledby="principles-title">
        <div class="hm-principles__statement">
          <h2 id="principles-title">Bukan sekadar banyak kelas. Yang dijaga adalah arah belajarnya.</h2>
          <p>
            Program disusun dengan kehati-hatian pada materi, bahasa, interaksi, dan visual.
            Ilmu ditempatkan sebagai jalan untuk memperbaiki ibadah, adab, keluarga, dan amanah pendidikan.
          </p>
        </div>
        <dl>
          {principles.map(([title, body]) => (
            <div>
              <dt>{title}</dt>
              <dd>{body}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="hm-contact" id="kontak" aria-labelledby="contact-title">
        <div>
          <h2 id="contact-title">Ceritakan kebutuhan Anda.</h2>
          <p>Tim Ihsanul Adab akan membantu memetakan program, jadwal, dan langkah awal yang realistis.</p>
        </div>
        <a class="hm-button hm-button--primary" href={consultationUrl}>Mulai konsultasi</a>
      </section>
    </main>

    <footer class="hm-footer">
      <p class="hm-footer__statement">Mendidik dengan adab. Menumbuhkan dengan ilmu. Mengokohkan dengan amal.</p>
      <div class="hm-footer__meta">
        <a class="hm-footer__brand" href="/">Yayasan Pendidikan Ihsanul Adab</a>
        <nav aria-label="Navigasi footer">
          <a href="/tentang-kami/">Tentang kami</a>
          <a href="#program">Program</a>
          <a href="/karir-pengabdian/">Karir</a>
          <a href={consultationUrl}>Kontak</a>
        </nav>
      </div>
    </footer>

    <nav class="hm-mobile-bottom-nav" aria-label="Navigasi bawah seluler">
      <a class="hm-bottom-nav__link" href="/" aria-current="page">Beranda</a>
      <a class="hm-bottom-nav__link" href="#jalur">Jalur</a>
      <a class="hm-bottom-nav__link" href="#program">Program</a>
      <a class="hm-bottom-nav__link" href={lmsUrl}>LMS</a>
      <details class="hm-bottom-nav__more">
        <summary>Menu</summary>
        <div>
          <a href="/tentang-kami/">Tentang kami</a>
          <a href="#cara-belajar">Cara belajar</a>
          <a href="/karir-pengabdian/">Karir &amp; pengabdian</a>
          <a href={consultationUrl}>Konsultasi program</a>
        </div>
      </details>
    </nav>
  </div>

  <script>
    const learningMaps = document.querySelectorAll('[data-flow-reveal]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduceMotion && 'IntersectionObserver' in window) {
      learningMaps.forEach((map) => map.classList.add('is-pending'));

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.18 });

      learningMaps.forEach((map) => observer.observe(map));
    } else {
      learningMaps.forEach((map) => map.classList.add('is-visible'));
    }

    const bottomNavLinks = document.querySelectorAll('.hm-bottom-nav__link[href^="#"], .hm-bottom-nav__link[href="/"]');

    const syncBottomNavigation = () => {
      const currentTarget = window.location.hash || '/';

      bottomNavLinks.forEach((link) => {
        if (link.getAttribute('href') === currentTarget) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    syncBottomNavigation();
    window.addEventListener('hashchange', syncBottomNavigation);
  </script>
</BaseLayout>
