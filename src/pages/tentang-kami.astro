    body: 'Menyiapkan ruang belajar yang menjaga akidah, fitrah, identitas Muslim, dan kecintaan kepada Al-Qur\'an.',
  },
  {
    title: 'Guru dan lembaga',
    body: 'Mendampingi pendidik serta lembaga Islam agar lebih rapi dalam sistem, kuat dalam nilai, dan jelas dalam arah.',
  },
  {
    title: 'Masyarakat pembelajar',
    body: 'Menyediakan program fondasi Islam, komunitas, dan dakwah digital yang mudah diakses tanpa kehilangan kehati-hatian ilmiah.',
  },
];

const principles = [
  'Berpijak pada Al-Qur\'an, Sunnah, dan pemahaman salafus shalih.',
  'Mengutamakan adab, keteladanan, dan amal sebelum sekadar keluasan informasi.',
  'Menyusun program sesuai kebutuhan nyata keluarga, peserta, guru, dan lembaga.',
  'Memilih bahasa, visual, dan pengalaman belajar yang terjaga, ramah, dan tidak berlebihan.',
];

const team = [
  ['Yahya Nursidik, S.Pd, M.T.', 'Pendiri dan Pembina Yayasan'],
  ['Dr. Muhammad Bisri Mustofa, S.Pd, M.Si', 'Ketua'],
  ['Agus Setiawan, S.Si', 'Staff Komunikasi, Informasi dan Pelayanan Publik'],
  ['Agus Gunawan, S.T, M.E', 'Executive Operation'],
  ['Taufik Rendi Anggara, S.Si., M.T.', 'Executive Operation'],
  ['Darizki Pratama, S.Kom, M.M.', 'Staff IT Department'],
  ['Ustadz Heykal Syaban, Lc., M.Ag', 'Pembina dan Pengajar The Father Project dan Ushuluna'],
  ['Ustadz Lanlan Tuhfatul Lanfas, Lc., M.A.', 'Pengajar'],
  ['Ustadz Rendi Rustandi', 'Pembina dan Pengajar Program Kaderisasi Guru Al-Qur\'an PAUD dan SD'],
  ['Dr. Azis Lukman Praja, M.Si', 'Pengajar dan Tim Pelatihan Headmaster & Teacher Academy'],
  ['Ustadzah Ishmahsarah Nur Alim, B.Ed.', 'Program Fitrah Journey dan Pengajar'],
  ['Ustadz Muhammad Abid Alimuddin, B.A., M.Ed.', 'Pengajar Program Ushuluna'],
