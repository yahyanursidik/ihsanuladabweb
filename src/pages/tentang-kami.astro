const integrityValues = [
  {
    title: 'Berlandaskan tauhid dan manhaj salaf',
    body: 'Arah pembinaan dirujukkan kepada Al-Qur\'an, Sunnah, dan pemahaman generasi terbaik umat.',
  },
  {
    title: 'Amanah dan transparan',
    body: 'Program, dana, kerja sama, dan pelayanan dikelola dengan tanggung jawab serta komunikasi yang jelas.',
  },
