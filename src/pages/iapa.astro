const whatsappUrl = 'https://wa.me/6285179676003';
---

<BaseLayout
  title="Ihsanul Adab Parenting Academy (IAPA)"
  description="IAPA adalah ruang belajar orang tua Muslim untuk membangun rumah yang lebih tenang, beradab, dan selaras dengan fitrah anak."
>
  <a class="skip-link" href="#konten">Lewati ke konten utama</a>

  <header class="site-header">
    <div class="topbar">
      <span>Ihsanul Adab Parenting Academy</span>
      <a href={whatsappUrl}>WhatsApp +62 851-7967-6003</a>
    </div>

    <div class="nav-shell">
      <a class="brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="58" height="58" />
        <span>
          <strong>Ihsanul Adab</strong>
          <small>Parenting Academy</small>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Navigasi IAPA">
        <a href="/">Beranda</a>
        <a href="/tentang-kami/">Tentang Kami</a>
        <a href="/karir-pengabdian/">Karir & Pengabdian</a>
        <details class="nav-dropdown">
          <summary>Program</summary>
          <div class="nav-program-panel">
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </details>
        {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>

      <a class="nav-cta" href="https://hub.ihsanuladab.or.id/">Akses LMS IA</a>

      <details class="mobile-menu">
        <summary aria-label="Buka menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-panel">
          <a href="/">Beranda</a>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <div class="mobile-program-group">
            <strong>Program</strong>
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
          {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
          <a class="button primary" href={whatsappUrl}>Hubungi Admin</a>
        </div>
      </details>
    </div>
  </header>

  <main id="konten">
    <section class="iapa-hero" aria-labelledby="iapa-title">
      <img src="/images/iapa-parenting-home-hero.png" alt="Sudut rumah belajar Muslim yang hangat dengan buku, catatan, dan mainan kayu tanpa figur makhluk bernyawa" />
      <div class="iapa-hero-content">
        <p class="eyebrow">Parenting Islami untuk rumah yang lebih tenang</p>
        <h1 id="iapa-title">Membersamai orang tua mendidik dengan adab, ilmu, dan kasih sayang.</h1>
        <p>
          IAPA membantu ibu dan ayah Muslim memahami anak, menata emosi, membangun
          rutinitas rumah, dan menghidupkan adab dengan cara yang bertahap.
        </p>
        <blockquote>
          Mendidik anak bukan hanya tentang mengubah anak. Ia juga perjalanan orang tua
          untuk belajar lebih sadar, lebih sabar, dan lebih dekat kepada Allah.
        </blockquote>
        <div class="hero-actions">
          <a class="button primary" href={whatsappUrl}>Konsultasi Program</a>
          <a class="button secondary" href="#program-iapa">Lihat Program</a>
        </div>
      </div>
    </section>

    <section class="iapa-principles" aria-label="Prinsip IAPA">
      {principles.map((principle) => <span>{principle}</span>)}
    </section>

    <section class="section iapa-intro" id="tentang-iapa">
      <div>
        <p class="eyebrow">Tentang IAPA</p>
        <h2>Ruang belajar orang tua yang ingin memperbaiki rumah tanpa kehilangan kelembutan.</h2>
      </div>
      <div class="stack">
        <p>
          Ihsanul Adab Parenting Academy adalah program pendidikan dan pendampingan orang
          tua di bawah Yayasan Pendidikan Ihsanul Adab untuk membangun pengasuhan Islami
          yang berlandaskan tauhid, adab, ilmu, dan fitrah anak.
        </p>
        <p>
          IAPA hadir sebagai sahabat belajar ibu dan ayah. Di sini, orang tua diajak
          memahami diri, membaca kebutuhan anak, lalu menyusun langkah perbaikan yang
          bisa dipraktikkan di rumah.
        </p>
        <p class="soft-quote">
          Orang tua yang belajar dengan tenang akan lebih mudah membimbing anak dengan
          cinta, batasan, dan keteladanan.
        </p>
      </div>
    </section>

    <section class="iapa-pain">
      <div>
        <p class="eyebrow">Jika ini terjadi di rumah Anda</p>
        <h2>Anda tidak sendirian, dan perubahan tidak harus dimulai dari langkah besar.</h2>
      </div>
      <div class="iapa-pain-grid">
        {painPoints.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="section iapa-focus">
      <div class="section-heading compact">
        <p class="eyebrow">Fokus pendampingan</p>
        <h2>Ilmu yang membumi untuk membangun adab dari rutinitas rumah sehari-hari.</h2>
      </div>
      <div class="iapa-list-grid">
        {focusAreas.map((item) => <article>{item}</article>)}
      </div>
    </section>

    <section class="section iapa-audience">
      <div class="section-heading compact">
        <p class="eyebrow">Untuk siapa?</p>
        <h2>Dirancang untuk keluarga yang ingin bertumbuh tanpa merasa harus sempurna.</h2>
      </div>
      <ul class="check-list">
        {audiences.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="section iapa-programs" id="program-iapa">
      <div class="section-heading">
        <p class="eyebrow">Program utama IAPA</p>
        <h2>Belajar bertahap, hangat, aplikatif, dan tetap berpijak pada nilai Islam.</h2>
      </div>
      <div class="iapa-program-grid">
        {programs.map((program) => (
          <article>
            <h3>{program.title}</h3>
            <p>{program.summary}</p>
            <ul>
              {program.points.map((point) => <li>{point}</li>)}
            </ul>
            <strong>{program.fit}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="section iapa-method" id="pendekatan">
      <div class="vision-panel">
        <p class="eyebrow">Pendekatan pembelajaran</p>
        <h2>Kami tidak menuntut orang tua menjadi sempurna. Kami menemani orang tua menjadi lebih sadar dan tenang.</h2>
      </div>
      <div class="mission-list">
        {approaches.map((approach) => (
          <article>
            <h3>{approach.title}</h3>
            <p>{approach.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section iapa-outcomes">
      <div class="section-heading compact">
        <p class="eyebrow">Perubahan yang diikhtiarkan</p>
        <h2>Yang kami kejar bukan rumah yang selalu rapi, tetapi rumah yang makin terarah.</h2>
      </div>
      <div class="iapa-outcome-grid">
        {outcomes.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section iapa-reasons">
      <div class="section-heading compact">
        <p class="eyebrow">Kenapa memilih IAPA?</p>
        <h2>Ruang belajar yang aman untuk bertanya, memahami, dan memperbaiki.</h2>
      </div>
      <div class="finder-grid">
        {reasons.map((reason) => (
          <article class="finder-card">
            <span>{reason}</span>
            <p>Disampaikan dengan bahasa yang ramah, tetap berlandaskan tauhid, Sunnah, dan adab.</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta iapa-cta" id="kontak">
      <div>
        <p class="eyebrow">Orang tua tidak harus berjalan sendiri</p>
        <h2>Belajar parenting tidak harus berat, membingungkan, atau melelahkan.</h2>
        <p>
          Mari bertumbuh bersama di Ihsanul Adab Parenting Academy. Hubungi admin untuk
          jadwal webinar, kelas Tumbuh Bersama Orang Tua, dan program tematik yang
          sesuai kebutuhan keluarga Anda.
        </p>
      </div>
      <div class="cta-actions">
        <a class="button primary" href={whatsappUrl}>WhatsApp Admin</a>
        <a class="button secondary" href="#program-iapa">Pilih Program</a>
      </div>
    </section>

  </main>

  <footer>
    <div class="footer-brand">
      <img src="/images/logo-ihsanul-adab.png" alt="" width="44" height="44" />
      <div>
        <p>Yayasan Pendidikan Ihsanul Adab</p>
        <span>2025-2026 - Yayasan Pendidikan Ihsanul Adab</span>
      </div>
    </div>
    <nav aria-label="Navigasi footer IAPA">
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </footer>

  <a class="floating-help" href={whatsappUrl}>WhatsApp Admin</a>
</BaseLayout>
