---
import {
  ArrowRight,
  Baby,
  BookOpenCheck,
  Brain,
  CalendarDays,
  Check,
  ChevronDown,
  CircleCheck,
  Compass,
  HandHeart,
  HeartHandshake,
  House,
  Menu,
  MessageCircle,
  MoonStar,
  NotebookTabs,
  ShieldCheck,
  Sprout,
  UsersRound,
  Waypoints,
} from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/iapa-redesign.css';

const whatsappUrl = 'https://wa.me/6285179676003';

const iapaProgramMenu = [
  ['Semua Program', '/#program'],
  ['The Father Project', '/program/the-father-project/'],
  ['The Fitrah Journey', '/program/the-fitrah-journey/'],
  ['Headmaster & Teacher Academy', '/program/headmaster-teacher-academy/'],
  ['Kaderisasi Guru Quran PAUD & SD', '/program/kaderisasi-guru-quran-paud-sd/'],
  ['IAIEE', '/program/iaiee/'],
  ['Ushuluna', '/program/ushuluna/'],
  ['DeenUp', '/program/deenup/'],
  ['IAIS Home-Based Learning', '/program/homebased-learning/'],
];

const iapaPrinciples = [
  {
    icon: MoonStar,
    title: 'Tauhid dan adab',
    detail: 'Arah pengasuhan dimulai dari niat, keteladanan, dan tanggung jawab kepada Allah.',
  },
  {
    icon: Sprout,
    title: 'Fitrah anak',
    detail: 'Anak dipahami sesuai tahap tumbuhnya, tanpa tergesa-gesa dan tanpa dibandingkan.',
  },
  {
    icon: House,
    title: 'Rumah yang tenang',
    detail: 'Kebiasaan baik dibangun melalui ritme yang realistis, hangat, dan dapat diulang.',
  },
];

const iapaPainPoints = [
  'Niat mendidik dengan lembut sering berubah menjadi marah ketika energi habis.',
  'Sulit membedakan kebutuhan anak, keinginan sesaat, dan batasan yang perlu dijaga.',
  'Rasa bersalah setelah konflik membuat orang tua bingung memulai perbaikan.',
  'Rutinitas ibadah, belajar, tidur, makan, dan screen time belum berjalan konsisten.',
  'Banyak teori sudah dibaca, tetapi langkah yang paling relevan belum ditemukan.',
];

const iapaParentingFlow = [
  {
    icon: HandHeart,
    title: 'Tenangkan diri',
    detail: 'Berhenti sejenak, membaca emosi, dan memilih respons sebelum menegur anak.',
  },
  {
    icon: Brain,
    title: 'Pahami kebutuhan',
    detail: 'Mengenali usia, tahap perkembangan, dan pesan di balik perilaku anak.',
  },
  {
    icon: Compass,
    title: 'Arahkan dengan adab',
    detail: 'Memberi batasan secara jelas, konsisten, lembut, dan tetap menjaga kehormatan anak.',
  },
  {
    icon: CalendarDays,
    title: 'Bangun ritme',
    detail: 'Mengulang kebiasaan kecil sampai menjadi rutinitas keluarga yang lebih sehat.',
  },
];

const iapaPrograms = [
  {
    icon: MessageCircle,
    title: 'Webinar Parenting Rutin',
    summary: 'Kelas daring singkat untuk membahas persoalan yang dekat dengan keseharian keluarga.',
    points: [
      'Tantrum, penolakan, dan anak yang sangat aktif',
      'Emosi orang tua yang mudah naik turun',
      'Screen time dan kebiasaan digital',
      'Disiplin tanpa teriakan',
    ],
    note: 'Cocok untuk orang tua yang membutuhkan wawasan praktis dan dapat segera dicoba.',
  },
  {
    icon: UsersRound,
    title: 'Kelas Tumbuh Bersama Orang Tua',
    summary: 'Program belajar berjenjang bagi orang tua yang ingin menjalani perubahan secara terarah.',
    points: [
      'Memahami diri sebelum membimbing anak',
      'Mengenal fitrah dan tahap perkembangan',
      'Menata rutinitas rumah yang Islami',
      'Berlatih komunikasi dan batasan',
    ],
    note: 'Cocok untuk keluarga yang ingin berproses perlahan dengan dukungan komunitas.',
  },
  {
    icon: NotebookTabs,
    title: 'Kelas Parenting Tematik',
    summary: 'Pembelajaran yang difokuskan pada kebutuhan keluarga, usia anak, atau pola belajar di rumah.',
    points: [
      'Usia dini dan SD awal',
      'Pengelolaan emosi ibu dan anak',
      'Adab harian serta pendampingan belajar',
      'Homeschooling dan home-based learning',
    ],
    note: 'Cocok untuk keluarga yang membutuhkan pembahasan lebih khusus dan kontekstual.',
  },
];

const iapaApproaches = [
  ['Bertahap dan realistis', 'Dimulai dari kebiasaan kecil yang dapat dijalankan, bukan target besar yang menambah rasa gagal.'],
  ['Adab sebelum teknik', 'Strategi pengasuhan dibangun di atas niat, akhlak, keteladanan, dan lisan yang baik.'],
  ['Sesuai fitrah dan usia', 'Orang tua dibantu membaca kebutuhan perkembangan tanpa memaksa anak menjadi dewasa sebelum waktunya.'],
  ['Empatik tanpa menghakimi', 'Ruang belajar menjaga orang tua tetap aman untuk bertanya, jujur, dan memperbaiki diri.'],
  ['Berpegang pada arah yang lurus', 'Materi dijaga selaras dengan tauhid, Sunnah, adab, dan pemahaman salafus shalih.'],
];

const iapaAudiences = [
  'Ibu dan ayah dengan anak usia dini atau SD awal.',
  'Keluarga homeschooling dan pendamping belajar anak di rumah.',
  'Orang tua yang ingin memperbaiki pola asuh tanpa dipermalukan.',
  'Keluarga yang ingin menanamkan adab dan rutinitas Islami secara bertahap.',
];

const iapaOutcomes = [
  'Lebih tenang saat merespons konflik, penolakan, dan emosi anak.',
  'Memiliki rutinitas rumah yang lebih jelas serta mungkin dijalankan.',
  'Mengajarkan adab melalui teladan, pembiasaan, dan komunikasi.',
  'Mempunyai peta langkah untuk melanjutkan perbaikan pengasuhan.',
];
---

<BaseLayout
  title="Ihsanul Adab Parenting Academy - Belajar Mengasuh dengan Adab"
  description="IAPA adalah ruang belajar orang tua Muslim untuk memahami anak, menata emosi, dan membangun rumah yang lebih tenang sesuai tauhid, adab, dan fitrah."
>
  <div class="hm-iapa">
    <a class="hm-iapa-skip" href="#konten">Lewati ke konten utama</a>

    <header class="hm-iapa-masthead hm-masthead">
      <div class="hm-iapa-nav-shell">
        <a class="hm-iapa-brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
          <img src="/images/logo-ihsanul-adab.png" alt="" width="46" height="46" />
          <span>
            <strong>Ihsanul Adab</strong>
            <small>Parenting Academy</small>
          </span>
        </a>

        <nav class="hm-iapa-desktop-nav" aria-label="Navigasi IAPA">
          <a href="#alur">Alur Belajar</a>
          <a href="#program-iapa">Program</a>
          <a href="#pendekatan">Pendekatan</a>
        </nav>

        <div class="hm-iapa-nav-actions">
          <details class="hm-iapa-program-menu">
            <summary>
              Program lain
              <ChevronDown size={16} strokeWidth={1.8} aria-hidden="true" />
            </summary>
            <div>
              {iapaProgramMenu.map(([label, href]) => <a href={href}>{label}</a>)}
              <a href="https://hub.ihsanuladab.or.id/">Akses LMS IA</a>
            </div>
          </details>
          <a class="hm-iapa-nav-cta" href={whatsappUrl}>
            <MessageCircle size={18} strokeWidth={1.8} aria-hidden="true" />
            <span>Tanya program</span>
          </a>
        </div>
      </div>
    </header>

    <main id="konten">
      <section class="hm-iapa-hero" aria-labelledby="iapa-title">
        <img
          src="/images/iapa-family-garden-hero.png"
          alt="Keluarga Muslim terdiri dari ayah, ibu, dan dua anak berjalan bersama menuju rumah, seluruhnya tampak dari belakang"
          width="1536"
          height="1024"
          fetchpriority="high"
        />
        <div class="hm-iapa-hero-shade" aria-hidden="true"></div>
        <div class="hm-iapa-hero-inner">
          <p class="hm-iapa-eyebrow">Ruang belajar orang tua Muslim</p>
          <h1 id="iapa-title">Ihsanul Adab Parenting Academy</h1>
          <p class="hm-iapa-hero-statement">Mengasuh dengan lebih tenang, memahami anak dengan lebih utuh.</p>
          <p class="hm-iapa-hero-copy">
            IAPA menemani ibu dan ayah menata emosi, membangun rutinitas, serta menghadirkan tauhid dan adab dalam kehidupan keluarga sehari-hari.
          </p>
          <div class="hm-iapa-actions">
            <a class="hm-iapa-button hm-iapa-button-primary" href={whatsappUrl}>
              Konsultasi program
              <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
            <a class="hm-iapa-button hm-iapa-button-quiet" href="#alur">
              Lihat alur belajar
              <Waypoints size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
          </div>
        </div>
      </section>

      <section class="hm-iapa-principles" aria-label="Tiga pijakan IAPA">
        {iapaPrinciples.map(({ icon: Icon, title, detail }) => (
          <article>
            <Icon size={24} strokeWidth={1.7} aria-hidden="true" />
            <div>
              <h2>{title}</h2>
              <p>{detail}</p>
            </div>
          </article>
        ))}
      </section>

      <section class="hm-iapa-question hm-iapa-section hm-iapa-reveal" id="tentang-iapa">
        <div class="hm-iapa-question-title">
          <h2>Mengapa mengasuh sering terasa lebih berat dari yang dibayangkan?</h2>
          <p>
            Karena orang tua bukan hanya menghadapi perilaku anak. Mereka juga membawa kelelahan, pengalaman masa lalu, perbedaan cara mengasuh, dan tuntutan kehidupan sehari-hari.
          </p>
        </div>
        <ol class="hm-iapa-pain-list">
          {iapaPainPoints.map((item, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <p>{item}</p>
            </li>
          ))}
        </ol>
      </section>

      <section class="hm-iapa-flow" id="alur" aria-labelledby="flow-title">
        <div class="hm-iapa-section">
          <div class="hm-iapa-flow-heading hm-iapa-reveal">
            <h2 id="flow-title">Bagaimana perubahan dimulai di rumah?</h2>
            <p>
              IAPA membantu orang tua bergerak melalui empat langkah yang dapat diulang setiap kali menghadapi dinamika pengasuhan.
            </p>
          </div>

          <ol class="hm-iapa-flowchart" aria-label="Alur pengasuhan IAPA">
            {iapaParentingFlow.map(({ icon: Icon, title, detail }, index) => (
              <li style={'--flow-index: ' + index}>
                <div class="hm-iapa-flow-icon">
                  <Icon size={26} strokeWidth={1.7} aria-hidden="true" />
                  <span>{String(index + 1).padStart(2, '0')}</span>
                </div>
                <h3>{title}</h3>
                <p>{detail}</p>
                {index < iapaParentingFlow.length - 1 && <ArrowRight class="hm-iapa-flow-arrow" size={24} strokeWidth={1.6} aria-hidden="true" />}
              </li>
            ))}
          </ol>

          <p class="hm-iapa-flow-note">
            Tujuannya bukan rumah tanpa masalah, melainkan orang tua yang semakin mampu merespons masalah dengan ilmu, adab, dan arah yang jelas.
          </p>
        </div>
      </section>

      <section class="hm-iapa-programs hm-iapa-section" id="program-iapa" aria-labelledby="program-title">
        <div class="hm-iapa-section-heading hm-iapa-reveal">
          <h2 id="program-title">Program mana yang paling sesuai untuk keluarga Anda?</h2>
          <p>Mulai dari kebutuhan yang sedang paling terasa. Setiap format memiliki kedalaman dan ritme belajar yang berbeda.</p>
        </div>

        <div class="hm-iapa-program-list">
          {iapaPrograms.map(({ icon: Icon, title, summary, points, note }, index) => (
            <article class="hm-iapa-reveal">
              <div class="hm-iapa-program-index">
                <Icon size={25} strokeWidth={1.7} aria-hidden="true" />
                <span>{String(index + 1).padStart(2, '0')}</span>
              </div>
              <div class="hm-iapa-program-copy">
                <h3>{title}</h3>
                <p>{summary}</p>
              </div>
              <ul>
                {points.map((point) => (
                  <li>
                    <Check size={17} strokeWidth={1.8} aria-hidden="true" />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
              <p class="hm-iapa-program-note">{note}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="hm-iapa-approach" id="pendekatan">
        <div class="hm-iapa-section">
          <div class="hm-iapa-approach-intro hm-iapa-reveal">
            <BookOpenCheck size={38} strokeWidth={1.5} aria-hidden="true" />
            <h2>Bagaimana IAPA menjaga proses belajar tetap membumi?</h2>
            <p>
              Materi diterjemahkan menjadi langkah yang dapat dicoba, diamati, lalu diperbaiki. Orang tua tidak didorong mengejar kesempurnaan.
            </p>
          </div>
          <ol class="hm-iapa-approach-list">
            {iapaApproaches.map(([title, body], index) => (
              <li class="hm-iapa-reveal">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="hm-iapa-audience hm-iapa-section">
        <div class="hm-iapa-section-heading hm-iapa-reveal">
          <h2>Apakah IAPA cocok untuk kondisi keluarga kami?</h2>
          <p>IAPA ditujukan bagi orang tua yang mau belajar dan memperbaiki langkah, bukan keluarga yang sudah merasa sempurna.</p>
        </div>
        <ul>
          {iapaAudiences.map((item) => (
            <li class="hm-iapa-reveal">
              <Baby size={22} strokeWidth={1.7} aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="hm-iapa-outcomes">
        <div class="hm-iapa-section">
          <div class="hm-iapa-outcome-heading hm-iapa-reveal">
            <HeartHandshake size={42} strokeWidth={1.5} aria-hidden="true" />
            <h2>Perubahan seperti apa yang diikhtiarkan?</h2>
          </div>
          <ul>
            {iapaOutcomes.map((item, index) => (
              <li class="hm-iapa-reveal">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p>{item}</p>
                <CircleCheck size={22} strokeWidth={1.7} aria-hidden="true" />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="hm-iapa-cta" id="kontak">
        <div class="hm-iapa-section">
          <ShieldCheck size={34} strokeWidth={1.5} aria-hidden="true" />
          <h2>Haruskah orang tua menunggu sampai keadaan rumah membaik untuk mulai belajar?</h2>
          <p>
            Tidak. Proses belajar justru dapat dimulai dari persoalan yang sedang dihadapi hari ini. Ceritakan kebutuhan keluarga Anda kepada admin IAPA.
          </p>
          <div class="hm-iapa-actions">
            <a class="hm-iapa-button hm-iapa-button-primary" href={whatsappUrl}>
              Bicara dengan admin
              <MessageCircle size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
            <a class="hm-iapa-text-link" href="#program-iapa">
              Bandingkan program
              <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="hm-iapa-footer">
      <a class="hm-iapa-brand" href="/">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="42" height="42" />
        <span>
          <strong>Yayasan Pendidikan Ihsanul Adab</strong>
          <small>Mendidik dengan adab, menumbuhkan dengan ilmu.</small>
        </span>
      </a>
      <nav aria-label="Navigasi footer IAPA">
        <a href="/tentang-kami/">Tentang Kami</a>
        <a href="/karir-pengabdian/">Karir & Pengabdian</a>
        <a href="/#program">Program Lain</a>
      </nav>
      <p>© 2026 Ihsanul Adab</p>
    </footer>

    <nav class="hm-mobile-bottom-nav hm-iapa-bottom-nav" aria-label="Navigasi bawah IAPA">
      <a href="/">
        <House size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Beranda</span>
      </a>
      <a href="#alur">
        <Waypoints size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Alur</span>
      </a>
      <a href="#program-iapa">
        <NotebookTabs size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Program</span>
      </a>
      <a href="#pendekatan">
        <BookOpenCheck size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Belajar</span>
      </a>
      <details>
        <summary>
          <Menu size={20} strokeWidth={1.8} aria-hidden="true" />
          <span>Menu</span>
        </summary>
        <div>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <a href="/#program">Semua Program</a>
          <a href={whatsappUrl}>WhatsApp Admin</a>
        </div>
      </details>
    </nav>
  </div>
</BaseLayout>
