const concerns = [
  'Sudah lama menjadi Muslim, tetapi masih merasa pemahaman agama belum tersusun dari dasar.',
  'Ingin mulai belajar Islam, namun bingung harus memulai dari materi apa dan guru siapa.',
  'Rutinitas ibadah berjalan, tetapi hati sering gelisah karena ilmu, niat, dan amal belum terhubung.',
  'Khawatir salah jalan dalam belajar karena banyaknya konten agama yang bercampur antara yang lurus dan yang rancu.',
];

const goals = [
  'Mengenal Allah, mengenal agama Islam, dan mengenal Rasulullah shallallahu alaihi wasallam dengan lebih benar.',
  "Memahami pokok tauhid, aqidah, ibadah, adab, dan manhaj dari Al-Qur'an dan Sunnah.",
  'Menata ilmu agar tidak hanya menjadi pengetahuan, tetapi menggerakkan amal harian.',
  'Membangun kebiasaan belajar yang ringan, bertahap, dan tetap menjaga kehati-hatian ilmiah.',
];

const audiences = [
  'Muslim pemula dan mualaf yang ingin belajar Islam dari fondasi paling penting.',
  'Orang tua yang ingin menguatkan dasar iman sebelum membimbing keluarga.',
  'Mahasiswa, pekerja, dan profesional yang membutuhkan ritme belajar ringkas namun terarah.',
  'Muslim yang ingin memperbaiki pemahaman agama dari awal tanpa merasa dihakimi.',
  'Penuntut ilmu yang ingin menata aqidah, ibadah dasar, adab belajar, dan manhaj dengan lebih rapi.',
];

const learningStages = [
  {
    title: 'Fondasi Aqidah dan Tauhid',
    points: [
      'Mengapa tauhid menjadi dasar seluruh amal.',
      'Tiga pertanyaan pokok: siapa Rabb-mu, apa agamamu, siapa Nabimu.',
      'Makna laa ilaaha illallah dalam keyakinan dan amal.',
      'Hal-hal yang merusak kemurnian tauhid.',
    ],
  },
  {
    title: 'Adab dan Manhaj Belajar',
    points: [
      'Niat, keikhlasan, dan adab penuntut ilmu.',
      "Adab terhadap Al-Qur'an, Sunnah, guru, dan sesama penuntut ilmu.",
      'Prinsip memahami agama dengan pemahaman salafus shalih.',
      'Cara menyikapi perbedaan, nasihat, dan konten agama di ruang digital.',
    ],
  },
  {
    title: 'Ibadah Harian dan Fiqh Dasar',
    points: [
      'Thaharah, wudhu, dan kebersihan ibadah.',
      'Shalat, puasa, zakat, dan fiqh praktis harian.',
      'Kesalahan umum dalam ibadah yang perlu diperbaiki bertahap.',
      'Menghubungkan ilmu ibadah dengan khusyuk dan ketundukan.',
    ],
  },
  {
    title: 'Akhlak dan Tazkiyatun Nafs',
    points: [
      'Akhlak Muslim dalam rumah, pekerjaan, pertemanan, dan masyarakat.',
      'Penyakit hati, muhasabah, dan jalan memperbaiki diri.',
      'Keteladanan Nabi, para sahabat, dan generasi salaf.',
      'Membiasakan amal kecil yang lebih mudah dijaga.',
    ],
  },
  {
    title: 'Islam dalam Kehidupan Nyata',
    points: [
      'Muamalah, keluarga, pekerjaan, dan interaksi sosial.',
      'Membaca masalah hidup dengan kacamata iman dan ilmu.',
      'Studi kasus ringan agar ilmu turun menjadi sikap dan keputusan.',
    ],
  },
];

const format = [
  {
    title: 'Ringkas',
    body: 'Materi disusun pendek dan fokus agar mudah diikuti di sela aktivitas harian.',
  },
  {
    title: 'Bertahap',
    body: 'Peserta diarahkan dari pokok iman menuju ibadah, adab, akhlak, dan praktik keseharian.',
  },
  {
    title: 'Reflektif',
    body: 'Setiap materi dihubungkan dengan pertanyaan muhasabah dan langkah amal sederhana.',
  },
  {
    title: 'Fleksibel',
    body: 'Belajar dapat dilakukan dari rumah melalui media daring dan bahan pendukung yang mudah diakses.',
  },
];

const approaches = [
  'Bahasa sederhana untuk orang dewasa, tanpa meremehkan kedalaman ilmu.',
  'Beban materi dijaga agar tidak menumpuk dan membuat peserta berhenti di tengah jalan.',
  'Penjelasan diarahkan kepada pemahaman, pengamalan, dan ketenangan dalam beragama.',
  "Rujukan dijaga agar selaras dengan Al-Qur'an, Sunnah, dan pemahaman salafus shalih.",
];

const assessments = [
  'Pertanyaan reflektif setelah materi.',
  'Muhasabah pribadi tanpa membuka aib yang tidak perlu.',
  'Studi kasus kehidupan nyata.',
  'Tantangan amal ringan yang bisa dijaga.',
];

const advancedPrograms = [
  "Tahsin dan tilawah Al-Qur'an.",
  'Bahasa Arab dasar.',
  'Fiqh keluarga dan kehidupan harian.',
  'Kajian tematik aqidah, adab, dan akhlak.',
  'Parenting dan keluarga Islami.',
  'Program pendalaman lain dalam ekosistem Ihsanul Adab.',
];

const differences = [
  'Fokus pada fondasi, bukan sekadar banyaknya materi.',
  'Ramah pemula, tetapi tetap menjaga kehati-hatian ilmiah.',
  'Menyentuh akal, hati, dan amal harian.',
  'Tidak dibuat untuk mengejar ranking atau tekanan akademik.',
  'Menjadi pintu masuk menuju pembelajaran Islam yang lebih tertata.',
];
---

<BaseLayout
  title="Ushuluna - The Essentials of Islam"
  description="Ushuluna adalah program pembelajaran Islam daring untuk memahami fondasi tauhid, aqidah, ibadah, adab, dan manhaj secara bertahap dan menenangkan."
>
  <a class="skip-link" href="#konten">Lewati ke konten utama</a>

  <header class="site-header ushuluna-site-header">
    <div class="topbar ushuluna-topbar">
      <span>Ushuluna - The Essentials of Islam</span>
      <a href={consultationUrl}>Konsultasi belajar</a>
    </div>

    <div class="nav-shell">
      <a class="brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="58" height="58" />
        <span>
          <strong>Ihsanul Adab</strong>
          <small>Ushuluna</small>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Navigasi Ushuluna">
        <a href="/">Beranda</a>
        <a href="/tentang-kami/">Tentang Kami</a>
        <a href="/karir-pengabdian/">Karir & Pengabdian</a>
        <details class="nav-dropdown">
          <summary>Program</summary>
          <div class="nav-program-panel">
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </details>
        {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>

      <a class="nav-cta ushuluna-nav-cta" href={lmsUrl}>Akses LMS IA</a>

      <details class="mobile-menu">
        <summary aria-label="Buka menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-panel">
          <a href="/">Beranda</a>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <div class="mobile-program-group">
            <strong>Program</strong>
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
          {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
          <a class="button primary" href={consultationUrl}>Mulai Belajar</a>
        </div>
      </details>
    </div>
  </header>

  <main id="konten">
    <section class="ushuluna-hero" aria-labelledby="ushuluna-title">
      <img
        src="/images/ushuluna-foundations-hero.png"
        alt="Still-life fondasi belajar Islam berisi mushaf tertutup, batu dasar, kompas, lampu, buku, dan pola geometri tanpa figur makhluk bernyawa"
      />
      <div class="ushuluna-hero-content">
        <p class="eyebrow">Ushuluna - The Essentials of Islam</p>
        <h1 id="ushuluna-title">Belajar Islam dari fondasi yang benar.</h1>
        <p>
          Program pembelajaran daring untuk memahami tauhid, aqidah, ibadah, adab,
          dan manhaj secara bertahap, ringkas, dan menenangkan hati.
        </p>
        <blockquote>
          Fondasi yang lurus membantu seorang Muslim lebih tenang dalam beribadah,
          lebih jernih dalam bersikap, dan lebih kuat saat menghadapi kehidupan.
        </blockquote>
        <div class="hero-actions">
          <a class="button primary" href={consultationUrl}>Mulai Belajar</a>
          <a class="button secondary" href="#tentang-ushuluna">Pelajari Ushuluna</a>
        </div>
      </div>
    </section>

    <section class="ushuluna-foundation" aria-label="Fondasi pembelajaran Ushuluna">
      {foundationSignals.map(([title, body]) => (
        <article>
          <strong>{title}</strong>
          <span>{body}</span>
        </article>
      ))}
    </section>

    <section class="section ushuluna-concern">
      <div>
        <p class="eyebrow">Kebutuhan yang sering dirasakan</p>
        <h2>Banyak Muslim ingin kembali belajar, tetapi belum tahu harus memulai dari mana.</h2>
      </div>
      <div class="ushuluna-concern-list">
        {concerns.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="ushuluna-answer" id="tentang-ushuluna">
      <div>
        <p class="eyebrow">Tentang Ushuluna</p>
        <h2>Pintu masuk untuk menata iman, ilmu, dan amal dari dasar.</h2>
      </div>
      <div>
        <p>
          Ushuluna dirancang untuk membantu peserta memahami pokok-pokok Islam dengan
          bahasa yang jernih dan alur yang bertahap. Program ini tidak mengejar banyak
          materi sekaligus, tetapi menguatkan hal paling mendasar agar ilmu lebih mudah
          diamalkan.
        </p>
      </div>
    </section>

    <section class="section ushuluna-about">
      <div>
        <p class="eyebrow">Arah belajar</p>
        <h2>Ilmu tidak berhenti sebagai pengetahuan, tetapi menggerakkan amal.</h2>
      </div>
      <div class="stack">
        <p>
          Materi disusun agar peserta mengenal dasar agama, memahami makna ibadah,
          memperbaiki adab belajar, dan mulai menata kebiasaan kecil yang bisa dijaga.
        </p>
        <div class="ushuluna-goal-grid">
          {goals.map((goal) => <span>{goal}</span>)}
        </div>
      </div>
    </section>

    <section class="section ushuluna-audience" id="untuk-siapa">
      <div>
        <p class="eyebrow">Untuk siapa program ini?</p>
        <h2>Ramah pemula, jelas untuk orang dewasa, dan tetap menjaga rujukan ilmu.</h2>
      </div>
      <div class="stack">
        <p>
          Tidak perlu latar belakang pesantren atau keilmuan khusus. Ushuluna cocok
          bagi peserta yang ingin belajar dengan tenang, bertahap, dan tidak merasa
          dihakimi karena baru memulai.
        </p>
        <ul class="check-list">
          {audiences.map((audience) => <li>{audience}</li>)}
        </ul>
      </div>
    </section>

    <section class="section ushuluna-materials" id="materi">
      <div class="section-heading">
        <p class="eyebrow">Materi utama</p>
        <h2>Ushuluna membimbing peserta melalui fondasi Islam yang paling dibutuhkan.</h2>
      </div>
      <div class="ushuluna-material-grid">
        {learningStages.map((stage) => (
          <article>
            <h3>{stage.title}</h3>
            <ul>
              {stage.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section ushuluna-structure" id="metode">
      <div>
        <p class="eyebrow">Format belajar</p>
        <h2>Ringan dijalani, tetapi tetap punya arah.</h2>
      </div>
      <div class="ushuluna-format-grid">
        {format.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section ushuluna-method">
      <article>
        <p class="eyebrow">Pendekatan pembelajaran</p>
        <h2>Materi dibuat agar ilmu lebih mudah menetap dan diamalkan.</h2>
        <ul>
          {approaches.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article>
        <p class="eyebrow">Refleksi dan latihan amal</p>
        <h2>Asesmen diarahkan kepada kesadaran, bukan tekanan.</h2>
        <ul>
          {assessments.map((item) => <li>{item}</li>)}
        </ul>
        <p>Tidak ada ranking. Tidak ada perlombaan popularitas. Yang dikejar adalah pemahaman yang benar dan amal yang lebih istiqamah.</p>
      </article>
    </section>

    <section class="section ushuluna-advanced">
      <div>
        <p class="eyebrow">Setelah fondasi</p>
        <h2>Ushuluna menjadi pintu masuk menuju pembelajaran yang lebih tertata.</h2>
      </div>
      <ul class="check-list">
        {advancedPrograms.map((program) => <li>{program}</li>)}
      </ul>
    </section>

    <section class="ushuluna-difference">
      <div>
        <p class="eyebrow">Mengapa Ushuluna berbeda?</p>
        <h2>Fokus pada akar, bukan sekadar banyaknya materi.</h2>
      </div>
      <div class="ushuluna-difference-grid">
        {differences.map((item) => <span>{item}</span>)}
      </div>
    </section>

    <section class="section ushuluna-closing">
      <article>
        <p class="eyebrow">Ushuluna</p>
        <h2>Sebuah perjalanan kembali ke dasar.</h2>
        <p>
          Untuk menata iman, menjernihkan hati, dan menguatkan langkah. Setiap materi
          diarahkan agar peserta mengambil satu pemahaman dan satu amal yang bisa
          dijaga dalam kehidupan nyata.
        </p>
      </article>
      <article>
        <h2>Belajar Islam bukan tentang menjadi paling pintar.</h2>
        <p>
          Ia adalah ikhtiar menjadi hamba yang lebih lurus niatnya, lebih tenang
          hatinya, dan lebih benar jalannya. Ushuluna hadir untuk menemani langkah awal
          itu dengan lembut dan terarah.
        </p>
        <a class="button primary" href={consultationUrl}>Mulai Belajar Ushuluna</a>
      </article>
    </section>

    <section class="cta ushuluna-cta" id="kontak">
      <div>
        <p class="eyebrow">The Essentials of Islam</p>
        <h2>Mulai dari fondasi yang bisa dipahami dan diamalkan.</h2>
        <p>
          Ceritakan kebutuhan belajar Anda kepada admin. Kami bantu arahkan langkah
          awal yang paling sesuai untuk mulai belajar bersama Ushuluna.
        </p>
      </div>
      <div class="cta-actions">
        <a class="button primary" href={consultationUrl}>Mulai Belajar</a>
        <a class="button secondary" href={whatsappUrl}>WhatsApp Admin</a>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-brand">
      <img src="/images/logo-ihsanul-adab.png" alt="" width="44" height="44" />
      <div>
        <p>Yayasan Pendidikan Ihsanul Adab</p>
        <span>Mendidik dengan adab. Menumbuhkan dengan ilmu. Mengokohkan dengan amal.</span>
      </div>
    </div>
    <nav aria-label="Navigasi footer Ushuluna">
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </footer>

  <a class="floating-help" href={consultationUrl}>Mulai Belajar</a>
</BaseLayout>
