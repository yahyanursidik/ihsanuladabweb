---
import {
  ArrowDown,
  ArrowRight,
  AudioLines,
  BookOpenCheck,
  ChevronDown,
  CircleCheck,
  Compass,
  ExternalLink,
  FileText,
  Headphones,
  HeartHandshake,
  House,
  Landmark,
  Layers3,
  Menu,
  MessageCircle,
  NotebookPen,
  Route,
  ShieldCheck,
  Sprout,
  TrainFront,
  UserRoundCheck,
  Waypoints,
} from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/ushuluna-redesign.css';

const programMenuItems = [
  ['Semua Program', '/#program'],
  ['Ihsanul Adab Parenting Academy', '/iapa/'],
  ['The Father Project', '/program/the-father-project/'],
  ['The Fitrah Journey', '/program/the-fitrah-journey/'],
  ['Headmaster & Teacher Academy', '/program/headmaster-teacher-academy/'],
  ['Kaderisasi Guru Quran PAUD & SD', '/program/kaderisasi-guru-quran-paud-sd/'],
  ['IAIEE', '/program/iaiee/'],
  ['DeenUp', '/program/deenup/'],
  ['IAIS Home-Based Learning', '/program/homebased-learning/'],
];

const studyRoute = [
  {
    icon: AudioLines,
    number: '01',
    title: 'Dengarkan',
    body: 'Simak materi inti dengan fokus, bahkan ketika waktu belajar harus menyesuaikan perjalanan dan pekerjaan.',
  },
  {
    icon: FileText,
    number: '02',
    title: 'Baca',
    body: 'Gunakan PDF pendamping untuk melihat kerangka, istilah penting, dan hubungan antarpokok bahasan.',
  },
  {
    icon: NotebookPen,
    number: '03',
    title: 'Catat',
    body: 'Tulis pemahaman, pertanyaan, dan perkara yang perlu diperiksa kembali agar ilmu tidak mudah berlalu.',
  },
  {
    icon: CircleCheck,
    number: '04',
    title: 'Amalkan',
    body: 'Pilih satu perbaikan yang dapat dijalankan dengan benar dan dijaga dalam keseharian.',
  },
];

const foundations = [
  {
    icon: Landmark,
    label: 'Arah',
    title: 'Tauhid',
    body: 'Mengenal Allah dan memahami tujuan hidup sebagai hamba sebelum membahas cabang ilmu yang lain.',
  },
  {
    icon: BookOpenCheck,
    label: 'Cara',
    title: 'Adab',
    body: 'Menjaga niat, cara belajar, sikap kepada dalil dan guru, serta kehati-hatian ketika bertanya.',
  },
  {
    icon: HeartHandshake,
    label: 'Amal',
    title: 'Ibadah',
    body: 'Menata amal harian dengan pemahaman yang benar agar ilmu melahirkan ketundukan, bukan sekadar informasi.',
  },
  {
    icon: Compass,
    label: 'Timbangan',
    title: 'Manhaj',
    body: 'Memahami agama berdasarkan Al-Qur\'an dan Sunnah dengan pemahaman salafus shalih.',
  },
];

const learningStages = [
  {
    icon: Landmark,
    index: '01',
    title: 'Aqidah dan tauhid',
    lead: 'Membenahi perkara yang menjadi dasar seluruh amal.',
    points: ['Tiga pertanyaan pokok', 'Makna tauhid dalam keyakinan dan amal', 'Perkara yang merusak kemurnian tauhid'],
  },
  {
    icon: Compass,
    index: '02',
    title: 'Adab dan manhaj belajar',
    lead: 'Menata cara menerima, memahami, dan menyampaikan ilmu.',
    points: ['Niat dan keikhlasan', 'Adab terhadap dalil dan pengajar', 'Menyikapi perbedaan dan konten digital'],
  },
  {
    icon: ShieldCheck,
    index: '03',
    title: 'Ibadah harian',
    lead: 'Menguatkan ilmu yang dibutuhkan untuk amal sehari-hari.',
    points: ['Thaharah dan wudhu', 'Shalat, puasa, serta fiqh dasar', 'Memperbaiki kesalahan secara bertahap'],
  },
  {
    icon: Sprout,
    index: '04',
    title: 'Akhlak dan tazkiyatun nafs',
    lead: 'Membawa ilmu ke dalam sikap, hati, dan relasi.',
    points: ['Akhlak di rumah dan pekerjaan', 'Muhasabah serta penyakit hati', 'Keteladanan Nabi dan generasi salaf'],
  },
  {
    icon: Route,
    index: '05',
    title: 'Islam dalam kehidupan nyata',
    lead: 'Melihat keputusan sehari-hari dengan timbangan iman dan ilmu.',
    points: ['Keluarga dan muamalah', 'Pekerjaan serta interaksi sosial', 'Studi kasus dan langkah perbaikan'],
  },
];

const concerns = [
  'Sudah lama menjadi Muslim, tetapi pemahaman agama terasa belum tersusun dari dasar.',
  'Ingin mulai belajar, namun bingung menentukan materi dan urutan yang perlu didahulukan.',
  'Rutinitas ibadah berjalan, tetapi hubungan antara ilmu, niat, dan amal belum terasa kuat.',
  'Sulit memilah konten agama di ruang digital dan membutuhkan rujukan yang lebih terarah.',
];

const audience = [
  'Muslim pemula dan mualaf yang ingin memahami fondasi paling penting.',
  'Mahasiswa, pekerja, dan profesional dengan waktu belajar yang terbatas.',
  'Orang tua yang ingin menguatkan dasar iman sebelum membimbing keluarga.',
  'Muslim yang ingin menata kembali aqidah, ibadah, adab belajar, dan manhaj dari awal.',
];

const principles = [
  'Bahasa dibuat jernih untuk orang dewasa tanpa meremehkan kedalaman ilmu.',
  'Beban belajar dijaga agar peserta dapat bertumbuh secara konsisten.',
  'Refleksi tidak diarahkan untuk membuka aib yang tidak perlu.',
  'Rujukan dijaga agar selaras dengan Al-Qur\'an, Sunnah, dan pemahaman salafus shalih.',
];

const continuations = [
  ['Tahsin dan tilawah', 'Menguatkan hubungan dengan Al-Qur\'an melalui bacaan yang lebih terjaga.'],
  ['Bahasa Arab dasar', 'Membuka jalan untuk memahami istilah dan sumber pembelajaran secara lebih utuh.'],
  ['Fiqh keluarga', 'Mendalami persoalan rumah, relasi, dan kehidupan harian dengan ilmu.'],
  ['Kajian tematik', 'Melanjutkan pembelajaran aqidah, adab, akhlak, dan tema yang lebih khusus.'],
];

const consultationUrl = 'https://berbagi.link/ypihsanuladab';
const whatsappUrl = 'https://wa.me/6285179676003';
const lmsUrl = 'https://hub.ihsanuladab.or.id/';
---

<BaseLayout
  title="Ushuluna - Fondasi Islam untuk Muslim Dewasa"
  description="Ushuluna membantu Muslim dewasa mempelajari tauhid, aqidah, ibadah, adab, dan manhaj secara bertahap melalui materi yang ringkas dan terarah."
>
  <div class="hm-ushuluna">
    <a class="hm-ushuluna-skip" href="#konten">Lewati ke konten utama</a>

    <header class="hm-ushuluna-header hm-masthead">
      <nav class="hm-ushuluna-nav hm-ushuluna-nav-left" aria-label="Navigasi program">
        <a href="#fondasi">Fondasi</a>
        <a href="#materi">Materi</a>
      </nav>

      <a class="hm-ushuluna-brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="48" height="48" />
        <span>
          <strong>Ushuluna</strong>
          <small>The Essentials of Islam</small>
        </span>
      </a>

      <div class="hm-ushuluna-header-actions">
        <details class="hm-ushuluna-program-menu">
          <summary>
            Program
            <ChevronDown size={16} strokeWidth={1.8} aria-hidden="true" />
          </summary>
          <div>
            {programMenuItems.map(([label, href]) => <a href={href}>{label}</a>)}
          </div>
        </details>
        <a class="hm-ushuluna-header-link" href={lmsUrl}>
          Akses LMS
          <ArrowRight size={17} strokeWidth={1.8} aria-hidden="true" />
        </a>
      </div>
    </header>

    <main id="konten">
      <section class="hm-ushuluna-hero" aria-labelledby="ushuluna-title">
        <img
          src="/images/ushuluna-kai-forward-seat-hero.png"
          alt="Seorang ikhwan dewasa tampak dari belakang duduk searah dengan kursi kereta biru dan abu-abu sambil belajar melalui audio dan PDF"
          width="1674"
          height="936"
          fetchpriority="high"
        />
        <div class="hm-ushuluna-hero-shade" aria-hidden="true"></div>
        <div class="hm-ushuluna-hero-inner">
          <p class="hm-ushuluna-kicker">Fondasi Islam untuk Muslim dewasa</p>
          <h1 id="ushuluna-title">Ushuluna</h1>
          <p class="hm-ushuluna-hero-statement">Belajar Islam dari dasar yang benar, di tengah hidup yang terus bergerak.</p>
          <p class="hm-ushuluna-hero-lede">
            Program daring untuk menata tauhid, aqidah, ibadah, adab, dan manhaj melalui alur belajar yang ringkas, bertahap, dan dapat diamalkan.
          </p>
          <div class="hm-ushuluna-actions">
            <a class="hm-ushuluna-button hm-ushuluna-button-primary" href={consultationUrl}>
              Mulai konsultasi
              <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
            <a class="hm-ushuluna-button hm-ushuluna-button-quiet" href="#rute-belajar">
              Lihat rute belajar
              <ArrowDown size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
          </div>
        </div>
        <p class="hm-ushuluna-hero-caption">
          <TrainFront size={17} strokeWidth={1.7} aria-hidden="true" />
          Bandung - Jakarta | belajar di sela perjalanan
        </p>
      </section>

      <section class="hm-ushuluna-route" id="rute-belajar" aria-labelledby="route-title">
        <div class="hm-ushuluna-section hm-ushuluna-route-inner">
          <div class="hm-ushuluna-route-heading hm-ushuluna-reveal">
            <p class="hm-ushuluna-kicker">Rute belajar fleksibel</p>
            <h2 id="route-title">Empat langkah agar materi tidak berhenti di layar.</h2>
          </div>
          <ol class="hm-ushuluna-route-map" aria-label="Alur belajar Ushuluna">
            {studyRoute.map(({ icon: Icon, number, title, body }, index) => (
              <li class="hm-ushuluna-reveal" style={'--route-order: ' + index}>
                <div>
                  <Icon size={24} strokeWidth={1.65} aria-hidden="true" />
                  <span>{number}</span>
                </div>
                <h3>{title}</h3>
                <p>{body}</p>
                {index < studyRoute.length - 1 && <ArrowRight class="hm-ushuluna-route-arrow" size={22} strokeWidth={1.6} aria-hidden="true" />}
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="hm-ushuluna-intro hm-ushuluna-section" aria-labelledby="intro-title">
        <div class="hm-ushuluna-reveal">
          <p class="hm-ushuluna-kicker">Mengapa Ushuluna</p>
          <h2 id="intro-title">Banyak materi belum tentu membuat arah belajar lebih jelas.</h2>
        </div>
        <div class="hm-ushuluna-intro-copy hm-ushuluna-reveal">
          <p>
            Ushuluna membantu peserta kembali kepada perkara yang paling mendasar. Materi tidak ditumpuk sekaligus, tetapi disusun agar hubungan antara keyakinan, ibadah, adab, dan kehidupan sehari-hari dapat terlihat.
          </p>
          <p>
            Tujuannya bukan mengejar banyaknya catatan. Peserta diarahkan untuk memahami prinsip, memeriksa dirinya, lalu membawa satu perbaikan ke dalam amal yang nyata.
          </p>
        </div>
      </section>

      <section class="hm-ushuluna-concerns">
        <div class="hm-ushuluna-section hm-ushuluna-concern-inner">
          <div class="hm-ushuluna-reveal">
            <p class="hm-ushuluna-kicker">Titik berangkat</p>
            <h2>Ketika ingin belajar, tetapi belum tahu mana yang harus didahulukan.</h2>
            <p>Ushuluna menolong peserta mengenali kebutuhan dasarnya sebelum bergerak ke pembahasan yang lebih jauh.</p>
          </div>
          <ol>
            {concerns.map((item, index) => (
              <li class="hm-ushuluna-reveal">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p>{item}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="hm-ushuluna-foundations hm-ushuluna-section" id="fondasi" aria-labelledby="foundations-title">
        <div class="hm-ushuluna-section-heading hm-ushuluna-reveal">
          <p class="hm-ushuluna-kicker">Peta fondasi</p>
          <h2 id="foundations-title">Empat penyangga untuk menata ilmu dan amal.</h2>
          <p>Setiap bagian saling terhubung. Tauhid memberi arah, adab menjaga cara, ibadah menghidupkan amal, dan manhaj menjadi timbangan.</p>
        </div>
        <ol class="hm-ushuluna-foundation-map">
          {foundations.map(({ icon: Icon, label, title, body }, index) => (
            <li class="hm-ushuluna-reveal">
              <div class="hm-ushuluna-foundation-marker">
                <Icon size={26} strokeWidth={1.6} aria-hidden="true" />
                <span>{String(index + 1).padStart(2, '0')}</span>
              </div>
              <p>{label}</p>
              <h3>{title}</h3>
              <span>{body}</span>
            </li>
          ))}
        </ol>
      </section>

      <section class="hm-ushuluna-materials" id="materi" aria-labelledby="materials-title">
        <div class="hm-ushuluna-section hm-ushuluna-material-inner">
          <div class="hm-ushuluna-material-heading hm-ushuluna-reveal">
            <p class="hm-ushuluna-kicker">Lima perhentian materi</p>
            <h2 id="materials-title">Dari keyakinan menuju keputusan sehari-hari.</h2>
            <p>Urutan materi membantu peserta melihat Islam sebagai jalan hidup yang utuh, bukan kumpulan tema yang terpisah.</p>
          </div>
          <div class="hm-ushuluna-material-list">
            {learningStages.map(({ icon: Icon, index, title, lead, points }) => (
              <article class="hm-ushuluna-reveal">
                <div class="hm-ushuluna-material-index">
                  <Icon size={25} strokeWidth={1.6} aria-hidden="true" />
                  <span>{index}</span>
                </div>
                <div>
                  <h3>{title}</h3>
                  <p>{lead}</p>
                </div>
                <ul>
                  {points.map((point) => (
                    <li>
                      <CircleCheck size={17} strokeWidth={1.75} aria-hidden="true" />
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="hm-ushuluna-method hm-ushuluna-section" id="metode" aria-labelledby="method-title">
        <div class="hm-ushuluna-method-lead hm-ushuluna-reveal">
          <Headphones size={42} strokeWidth={1.4} aria-hidden="true" />
          <p class="hm-ushuluna-kicker">Dirancang untuk ritme dewasa</p>
          <h2 id="method-title">Ringkas untuk diikuti, cukup terarah untuk membangun kebiasaan.</h2>
          <p>Belajar dapat ditempatkan di sela perjalanan, sebelum bekerja, atau setelah urusan rumah selesai tanpa kehilangan urutan.</p>
          <a href={lmsUrl} class="hm-ushuluna-inline-link">
            Buka LMS Ihsanul Adab
            <ExternalLink size={17} strokeWidth={1.8} aria-hidden="true" />
          </a>
        </div>
        <div class="hm-ushuluna-method-grid">
          <article class="hm-ushuluna-reveal">
            <AudioLines size={25} strokeWidth={1.6} aria-hidden="true" />
            <h3>Materi audio</h3>
            <p>Mendukung peserta yang perlu belajar sambil berpindah tempat atau menjalani rutinitas.</p>
          </article>
          <article class="hm-ushuluna-reveal">
            <FileText size={25} strokeWidth={1.6} aria-hidden="true" />
            <h3>PDF pendamping</h3>
            <p>Memberi kerangka baca yang dapat ditandai dan dilihat kembali ketika peserta membutuhkan penguatan.</p>
          </article>
          <article class="hm-ushuluna-reveal">
            <NotebookPen size={25} strokeWidth={1.6} aria-hidden="true" />
            <h3>Refleksi terjaga</h3>
            <p>Pertanyaan dan catatan diarahkan kepada muhasabah tanpa mendorong peserta membuka aib.</p>
          </article>
          <article class="hm-ushuluna-reveal">
            <CircleCheck size={25} strokeWidth={1.6} aria-hidden="true" />
            <h3>Langkah amal</h3>
            <p>Setiap bagian ditutup dengan perbaikan ringan yang relevan dan dapat dilanjutkan.</p>
          </article>
        </div>
      </section>

      <section class="hm-ushuluna-audience">
        <div class="hm-ushuluna-section hm-ushuluna-audience-inner">
          <div class="hm-ushuluna-reveal">
            <p class="hm-ushuluna-kicker">Untuk siapa</p>
            <h2>Untuk Muslim yang ingin kembali menata dasar tanpa merasa dihakimi.</h2>
            <UserRoundCheck size={44} strokeWidth={1.4} aria-hidden="true" />
          </div>
          <ul>
            {audience.map((item) => (
              <li class="hm-ushuluna-reveal">
                <CircleCheck size={21} strokeWidth={1.7} aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="hm-ushuluna-principles hm-ushuluna-section" aria-labelledby="principles-title">
        <div class="hm-ushuluna-reveal">
          <p class="hm-ushuluna-kicker">Cara kami menjaga proses</p>
          <h2 id="principles-title">Ramah bagi pemula, tetap berhati-hati dalam ilmu.</h2>
        </div>
        <ul>
          {principles.map((item) => (
            <li class="hm-ushuluna-reveal">
              <ShieldCheck size={21} strokeWidth={1.7} aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="hm-ushuluna-continuation" aria-labelledby="continuation-title">
        <div class="hm-ushuluna-section hm-ushuluna-continuation-inner">
          <div class="hm-ushuluna-section-heading hm-ushuluna-reveal">
            <p class="hm-ushuluna-kicker">Setelah fondasi</p>
            <h2 id="continuation-title">Lanjutkan perjalanan sesuai kebutuhan ilmu.</h2>
            <p>Ushuluna menjadi pintu masuk. Setelah dasarnya lebih tertata, peserta dapat melanjutkan ke pembelajaran yang lebih khusus.</p>
          </div>
          <div class="hm-ushuluna-continuation-list">
            {continuations.map(([title, body], index) => (
              <article class="hm-ushuluna-reveal">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                </div>
                <ArrowRight size={20} strokeWidth={1.6} aria-hidden="true" />
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="hm-ushuluna-cta" id="kontak">
        <div class="hm-ushuluna-section hm-ushuluna-cta-inner">
          <Layers3 size={42} strokeWidth={1.4} aria-hidden="true" />
          <p class="hm-ushuluna-kicker">Mulai dari yang paling mendasar</p>
          <h2>Fondasi yang lurus membantu langkah tetap terarah, di mana pun perjalanan berlangsung.</h2>
          <p>Ceritakan kebutuhan dan ritme belajar Anda. Admin akan membantu menjelaskan alur program dan langkah awal yang tersedia.</p>
          <div class="hm-ushuluna-actions">
            <a class="hm-ushuluna-button hm-ushuluna-button-primary" href={consultationUrl}>
              Konsultasikan program
              <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
            </a>
            <a class="hm-ushuluna-button hm-ushuluna-button-outline" href={whatsappUrl}>
              WhatsApp admin
              <ExternalLink size={17} strokeWidth={1.8} aria-hidden="true" />
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="hm-ushuluna-footer">
      <div class="hm-ushuluna-footer-main">
        <div>
          <p class="hm-ushuluna-kicker">Ushuluna</p>
          <h2>Kembali ke dasar. Menata arah. Menjaga amal.</h2>
        </div>
        <Route size={42} strokeWidth={1.3} aria-hidden="true" />
      </div>
      <div class="hm-ushuluna-footer-meta">
        <a class="hm-ushuluna-brand" href="/">
          <img src="/images/logo-ihsanul-adab.png" alt="" width="42" height="42" />
          <span>
            <strong>Ihsanul Adab</strong>
            <small>Mendidik dengan adab, menumbuhkan dengan ilmu.</small>
          </span>
        </a>
        <nav aria-label="Navigasi footer">
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <a href="/#program">Program Lain</a>
        </nav>
        <p>&copy; 2026 Ihsanul Adab</p>
      </div>
    </footer>

    <nav class="hm-mobile-bottom-nav hm-ushuluna-bottom-nav" aria-label="Navigasi bawah Ushuluna">
      <a href="/">
        <House size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Beranda</span>
      </a>
      <a href="#rute-belajar">
        <Waypoints size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Alur</span>
      </a>
      <a href="#materi">
        <BookOpenCheck size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Materi</span>
      </a>
      <a href={whatsappUrl}>
        <MessageCircle size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Tanya</span>
      </a>
      <details>
        <summary>
          <Menu size={20} strokeWidth={1.8} aria-hidden="true" />
          <span>Menu</span>
        </summary>
        <div>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <a href="/#program">Semua Program</a>
          <a href={lmsUrl}>Akses LMS</a>
        </div>
      </details>
    </nav>
  </div>

  <script>
    const revealItems = document.querySelectorAll('.hm-ushuluna-reveal');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduceMotion || !('IntersectionObserver' in window)) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries, currentObserver) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            currentObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.12 },
      );

      revealItems.forEach((item) => observer.observe(item));
    }
  </script>
</BaseLayout>
