---
import BaseLayout from '../../layouts/BaseLayout.astro';

const navItems = [
  ['Beranda', '/'],
  ['Tentang Kami', '/tentang-kami/'],
  ['Karir & Pengabdian', '/karir-pengabdian/'],
  ['Tentang IAIEE', '#tentang-iaiee'],
  ['Layanan', '#layanan'],
  ['Paket', '#paket'],
  ['FAQ', '#faq'],
