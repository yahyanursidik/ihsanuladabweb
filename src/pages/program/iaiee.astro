const services = [
  {
    title: 'Diagnosa Mutu Lembaga',
    body: 'Pemetaan kondisi kurikulum, pembelajaran, SDM, tata kelola, budaya adab, dan kesiapan dokumen melalui data yang tersedia.',
  },
  {
    title: 'Kurikulum dan Perangkat Pembelajaran',
    body: 'Review, perapihan, dan penyusunan perangkat agar tujuan, materi, asesmen, dan praktik kelas lebih selaras.',
  },
  {
    title: 'Supervisi Pembelajaran',
    body: 'Membangun instrumen observasi, rubrik, forum tindak lanjut, dan ritme pembinaan guru yang membina, bukan sekadar menilai.',
  },
  {
    title: 'Penguatan Pimpinan dan Tim',
    body: 'Pendampingan kepala sekolah, koordinator, dan pengelola agar mampu membaca masalah, menentukan prioritas, dan menggerakkan tim.',
  },
  {
    title: 'Akreditasi dan Bukti Mutu',
    body: 'Pemetaan bukti, perapihan dokumen, simulasi, dan alur kerja agar proses akreditasi lebih tertib dan tenang.',
  },
  {
    title: 'Transformasi Digital Pendidikan',
    body: 'Pemilihan sistem, alur dokumentasi, dan dashboard sederhana agar monitoring berjalan tanpa membebani tim.',
  },
  {
    title: 'Riset dan Pengembangan Program',
    body: 'Menyusun modul, instrumen evaluasi, dan kajian kebutuhan sebagai dasar pengembangan program baru.',
  },
  {
    title: 'Pendampingan Custom',
    body: 'Solusi remote, onsite, atau hybrid untuk tantangan khusus lembaga pendidikan Islam formal maupun nonformal.',
  },
];

const packages = [
  {
    name: 'IAIEE Insight',
    fit: 'Untuk lembaga yang ingin mengetahui kondisi dan prioritas awal.',
    outputs: ['Sesi konsultasi awal', 'Pemetaan masalah utama', 'Ringkasan prioritas 30-90 hari', 'Rekomendasi langkah awal'],
  },
  {
    name: 'IAIEE Assurance',
    fit: 'Untuk lembaga yang siap menata sistem mutu secara bertahap.',
    outputs: ['Diagnosa dokumen dan praktik', 'Roadmap mutu', 'Toolkit supervisi', 'Pendampingan implementasi berkala'],
  },
  {
    name: 'IAIEE Excellence',
    fit: 'Untuk lembaga yang membutuhkan transformasi menyeluruh.',
    outputs: ['Semua output Assurance', 'Pendampingan intensif', 'Akreditasi dan digitalisasi', 'Evaluasi dampak dan laporan berkala'],
  },
];

const process = [
  {
    title: 'Konsultasi dan penjajakan',
    body: 'Kami memahami profil lembaga, jenjang, visi, kebutuhan mendesak, dan batasan sumber daya yang dimiliki.',
  },
  {
    title: 'Diagnosa berbasis bukti',
    body: 'Tim membaca dokumen, data, alur kerja, atau sampling proses belajar untuk melihat akar masalah secara lebih jernih.',
  },
  {
    title: 'Roadmap dan prioritas',
    body: 'Rekomendasi disusun dalam langkah yang jelas: apa yang dibenahi, siapa penanggung jawabnya, dan kapan dievaluasi.',
  },
