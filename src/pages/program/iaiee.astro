  'Visi Islam lembaga sudah kuat, tetapi standar kerja harian belum seragam.',
  'Dokumen kurikulum, supervisi, dan evaluasi ada, namun belum menjadi kebiasaan mutu.',
  'Guru dan pimpinan bersemangat, tetapi perlu alat kerja yang jelas agar perubahan tidak bergantung pada satu orang.',
  'Akreditasi atau ekspansi program sudah dekat, sementara data, bukti, dan alur kerja belum tertata.',
];

const principles = [
  {
    title: 'Tauhid dan adab sebagai arah',
    body: 'Pembenahan mutu diarahkan sebagai amanah ibadah, bukan sekadar mengejar dokumen atau tampilan profesional.',
  },
  {
    title: 'Data sebelum keputusan',
    body: 'Setiap rekomendasi dimulai dari membaca dokumen, praktik, ritme kerja, dan kebutuhan riil lembaga.',
  },
  {
    title: 'Sistem yang bisa dijalankan',
    body: 'Standar, rubrik, SOP, dan roadmap dibuat ringkas agar dapat dipakai oleh kepala sekolah, guru, dan tim administrasi.',
  },
  {
