const outputs = [
  'Peta masalah dan prioritas mutu lembaga.',
  'Roadmap perbaikan 30, 90, atau 180 hari.',
  'Instrumen supervisi, rubrik observasi, dan format tindak lanjut.',
  'Rekomendasi kurikulum, perangkat ajar, asesmen, dan budaya kelas.',
  'Pemetaan bukti akreditasi dan perapihan dokumen inti.',
  'Rencana penguatan SDM dan forum pembinaan berkala.',
  'Alur dokumentasi digital yang sederhana dan bisa dilanjutkan oleh tim.',
];

const impacts = [
  'Keputusan lebih tenang karena berbasis data, bukan sekadar dugaan.',
  'Guru memiliki standar kerja dan umpan balik yang lebih jelas.',
  'Pimpinan lebih mudah memonitor mutu tanpa harus mengejar semua detail sendiri.',
  'Dokumen dan bukti mutu tertata sesuai kebutuhan lembaga.',
  'Budaya adab lebih mudah diterjemahkan menjadi kebiasaan kerja harian.',
  'Tim memiliki arah perbaikan yang dapat dievaluasi bersama.',
];

const faqs = [
  ['Apakah IAIEE hanya untuk sekolah formal?', 'Tidak. IAIEE dapat mendampingi sekolah, rumah belajar, madrasah, komunitas pendidikan, dan lembaga nonformal sesuai kebutuhan.'],
  ['Apakah harus mulai dari paket besar?', 'Tidak. Lembaga bisa mulai dari konsultasi atau diagnosa awal untuk mengetahui prioritas yang paling mendesak.'],
  ['Bisa dilakukan online?', 'Bisa. Pendampingan dapat dilakukan online, onsite, atau hybrid, tergantung jenis layanan dan kesiapan lembaga.'],
  ['Apakah pendekatannya sesuai manhaj salaf?', "IAIEE menjaga tauhid, adab, dan prinsip Al-Qur'an serta Sunnah dengan pemahaman salafus shalih sebagai arah utama. Pembahasan manajemen dan mutu diposisikan sebagai alat bantu, bukan pengganti bimbingan agama."],
  ['Berapa lama pendampingan berjalan?', 'Durasi menyesuaikan kebutuhan. Banyak lembaga mulai dari roadmap 90 hari, lalu melanjutkan ke pendampingan 6-12 bulan bila diperlukan.'],
];
---

<BaseLayout
  title="IAIEE - Ihsanul Adab Institute for Educational Excellence"
  description="IAIEE mendampingi lembaga pendidikan Islam membangun sistem mutu yang terpercaya, terukur, dan berkelanjutan berlandaskan tauhid dan adab."
>
  <a class="skip-link" href="#konten">Lewati ke konten utama</a>

  <header class="site-header iaiee-site-header">
    <div class="topbar iaiee-topbar">
      <span>Ihsanul Adab Institute for Educational Excellence</span>
      <a href={consultationUrl}>Konsultasi mutu lembaga</a>
    </div>

    <div class="nav-shell">
      <a class="brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="58" height="58" />
        <span>
          <strong>Ihsanul Adab</strong>
          <small>IAIEE</small>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Navigasi IAIEE">
        <a href="/">Beranda</a>
        <a href="/tentang-kami/">Tentang Kami</a>
        <a href="/karir-pengabdian/">Karir & Pengabdian</a>
        <details class="nav-dropdown">
          <summary>Program</summary>
          <div class="nav-program-panel">
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </details>
        {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>

      <a class="nav-cta iaiee-nav-cta" href={lmsUrl}>Akses LMS IA</a>

      <details class="mobile-menu">
        <summary aria-label="Buka menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-panel">
          <a href="/">Beranda</a>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <div class="mobile-program-group">
            <strong>Program</strong>
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
          {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
          <a class="button primary" href={consultationUrl}>Konsultasi Mutu</a>
        </div>
      </details>
    </div>
  </header>

  <main id="konten">
    <section class="iaiee-hero" aria-labelledby="iaiee-title">
      <img
        src="/images/iaiee-quality-assurance-hero.png"
        alt="Meja kerja mutu pendidikan berisi folder, dokumen audit, tablet grafik abstrak, kompas, dan mushaf tertutup tanpa figur makhluk bernyawa"
      />
      <div class="iaiee-hero-content">
        <p class="eyebrow">IAIEE</p>
        <h1 id="iaiee-title">Mutu lembaga yang terpercaya, terukur, dan tetap beradab.</h1>
        <p>
          IAIEE mendampingi lembaga pendidikan Islam menata kurikulum, pembelajaran,
          SDM, tata kelola, akreditasi, dan budaya mutu tanpa kehilangan arah tauhid
          dan adab.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={consultationUrl}>Konsultasi Mutu</a>
          <a class="button secondary" href="#diagnosa">Mulai dari Diagnosa</a>
        </div>
        <small>Online, onsite, atau hybrid sesuai kebutuhan dan kesiapan lembaga.</small>
      </div>
    </section>

    <section class="iaiee-principles" aria-label="Ringkasan pendekatan IAIEE">
      {qualitySignals.map(([title, body]) => (
        <article>
          <strong>{title}</strong>
          <span>{body}</span>
        </article>
      ))}
    </section>

    <section class="section iaiee-intro" id="tentang-iaiee">
      <div>
        <p class="eyebrow">Mitra mutu pendidikan Islam</p>
        <h2>IAIEE membantu lembaga naik mutu tanpa bergerak serampangan.</h2>
      </div>
      <div class="stack">
        <p>
          Banyak lembaga memiliki niat yang baik, guru yang berjuang, dan visi Islam
          yang kuat. Tantangannya sering muncul pada sistem: standar belum jelas,
          dokumen belum hidup, supervisi belum teratur, dan evaluasi belum menjadi
          kebiasaan.
        </p>
        <p>
          Karena itu IAIEE bekerja dari diagnosa menuju roadmap, lalu mendampingi
          implementasi agar perubahan tidak berhenti sebagai materi pelatihan.
        </p>
      </div>
    </section>

    <section class="section iaiee-diagnosis" id="diagnosa">
      <div class="section-heading compact">
        <p class="eyebrow">Kapan lembaga membutuhkan IAIEE?</p>
        <h2>Ketika mutu perlu dibaca dengan jernih sebelum dibenahi.</h2>
      </div>
      <div class="iaiee-concern-grid">
        {concerns.map((concern, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{concern}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section iaiee-assurance">
      <div class="section-heading">
        <p class="eyebrow">Prinsip pendampingan</p>
        <h2>Kepercayaan dibangun dari arah yang benar dan proses yang rapi.</h2>
      </div>
      <div class="iaiee-assurance-grid">
        {principles.map((principle) => (
          <article>
            <h3>{principle.title}</h3>
            <p>{principle.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="iaiee-quality-band">
      <div>
        <p class="eyebrow">Batasan yang dijaga</p>
        <h2>Profesional, tetapi tidak kehilangan ruh pendidikan Islam.</h2>
      </div>
      <div>
        <p>Manajemen mutu dipakai sebagai alat bantu untuk menunaikan amanah pendidikan dengan lebih tertib.</p>
        <p>Setiap rekomendasi tetap diarahkan agar selaras dengan tauhid, adab, dan kebutuhan lembaga.</p>
        <p>Dokumentasi, digitalisasi, dan akreditasi tidak dijadikan tujuan akhir, tetapi sarana untuk menjaga amanah.</p>
      </div>
    </section>

    <section class="section iaiee-services" id="layanan">
      <div class="section-heading">
        <p class="eyebrow">Layanan IAIEE</p>
        <h2>Pilih layanan sesuai kebutuhan, atau mulai dari diagnosa untuk menentukan prioritas.</h2>
      </div>
      <div class="iaiee-service-grid">
        {services.map((service) => (
          <article>
            <h3>{service.title}</h3>
            <p>{service.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section iaiee-packages">
      <div class="section-heading">
        <p class="eyebrow">Paket pendampingan</p>
        <h2>Mulai dari yang paling realistis untuk kondisi lembaga saat ini.</h2>
      </div>
      <div class="iaiee-package-grid">
        {packages.map((item) => (
          <article>
            <h3>{item.name}</h3>
            <p>{item.fit}</p>
            <strong>Output utama:</strong>
            <ul>
              {item.outputs.map((output) => <li>{output}</li>)}
            </ul>
            <a class="button primary" href={consultationUrl}>Konsultasikan Paket</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section iaiee-process" id="alur">
      <div>
        <p class="eyebrow">Alur kerja</p>
        <h2>Dari konsultasi awal sampai evaluasi dampak.</h2>
      </div>
      <div class="iaiee-process-list">
        {process.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section iaiee-output">
      <div class="section-heading">
        <p class="eyebrow">Output nyata</p>
        <h2>Hasil pendampingan dibuat agar langsung bisa dipakai oleh tim.</h2>
      </div>
      <ul class="check-list iaiee-output-list">
        {outputs.map((output) => <li>{output}</li>)}
      </ul>
    </section>

    <section class="iaiee-impact">
      <div>
        <p class="eyebrow">Dampak yang dikejar</p>
        <h2>Mutu terlihat dalam sistem, terasa dalam budaya.</h2>
      </div>
      <div class="iaiee-impact-grid">
        {impacts.map((impact) => <span>{impact}</span>)}
      </div>
    </section>

    <section class="section iaiee-faq" id="faq">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Pertanyaan yang sering ditanyakan.</h2>
      </div>
      <div class="iaiee-faq-list">
        {faqs.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="cta iaiee-cta" id="kontak">
      <div>
        <p class="eyebrow">Siap menata mutu lembaga?</p>
        <h2>Mulai dari konsultasi awal dan diagnosa kebutuhan.</h2>
        <p>
          Ceritakan kondisi lembaga Anda. Kami bantu menentukan langkah awal yang
          paling realistis, terukur, dan tetap menjaga arah tauhid serta adab.
        </p>
      </div>
      <div class="cta-actions">
        <a class="button primary" href={consultationUrl}>Konsultasi Mutu</a>
        <a class="button secondary" href={whatsappUrl}>WhatsApp Admin</a>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-brand">
      <img src="/images/logo-ihsanul-adab.png" alt="" width="44" height="44" />
      <div>
        <p>Yayasan Pendidikan Ihsanul Adab</p>
        <span>Mendidik dengan adab. Menumbuhkan dengan ilmu. Mengokohkan dengan amal.</span>
      </div>
    </div>
    <nav aria-label="Navigasi footer IAIEE">
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </footer>

  <a class="floating-help" href={consultationUrl}>Konsultasi</a>
</BaseLayout>
