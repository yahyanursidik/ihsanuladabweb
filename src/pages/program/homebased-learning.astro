  <script>
    const hblRevealTargets = document.querySelectorAll(
      '.hm-hbl main section > div, .hm-hbl main section > ol, .hm-hbl main section > ul, .hm-hbl main article',
    );
    const hblReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    hblRevealTargets.forEach((item) => item.classList.add('hm-hbl-reveal'));

    if (hblReduceMotion || !('IntersectionObserver' in window)) {
      hblRevealTargets.forEach((item) => item.classList.add('is-visible'));
    } else {
      const hblObserver = new IntersectionObserver(
        (entries, currentObserver) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            currentObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.1 },
      );

      hblRevealTargets.forEach((item) => hblObserver.observe(item));
    }
  </script>
