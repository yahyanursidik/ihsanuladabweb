---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  ArrowDown,
  ArrowRight,
  BookOpenCheck,
  Boxes,
  CalendarCheck,
  ChartNoAxesCombined,
  Check,
  CircleCheck,
  ClipboardCheck,
  Compass,
  ExternalLink,
  GraduationCap,
  HandHeart,
  HeartHandshake,
  House,
  LampDesk,
  Leaf,
  Menu,
  MessageCircle,
  NotebookTabs,
  Palette,
  Parentheses,
  Puzzle,
  School,
  ShieldCheck,
  Sparkles,
  Sprout,
  SunMedium,
  UsersRound,
  Waypoints,
} from '@lucide/astro';
import '../../styles/homebased-learning-redesign.css';

const consultationUrl = 'https://berbagi.link/ypihsanuladab';
const whatsappUrl = 'https://wa.me/6285179676003';
const lmsUrl = 'https://hub.ihsanuladab.or.id/';

const navItems = [
  ['Beranda', '/'],
  ['Tentang Kami', '/tentang-kami/'],
  ['Karir & Pengabdian', '/karir-pengabdian/'],
  ['Tentang HBL', '#tentang-hbl'],
  ['Jenjang', '#program-aktif'],
  ['Kurikulum', '#struktur'],
