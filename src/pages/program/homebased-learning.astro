const audiences = [
  'Keluarga Muslim yang memilih homeschooling atau home-based learning dengan arahan kurikulum.',
  'Orang tua yang ingin lebih dekat mendampingi proses belajar, adab, dan ibadah anak.',
  'Keluarga diaspora yang membutuhkan pendidikan Islam dari rumah dengan struktur yang jelas.',
  'Anak usia dini dan sekolah dasar yang membutuhkan ritme belajar hangat, aman, dan tidak terburu-buru.',
  'Keluarga yang ingin menguatkan fungsi rumah sebagai madrasah pertama.',
];

const pillars = [
  {
    title: 'Tauhid dan adab harian',
    body: 'Pembelajaran diarahkan agar anak mengenal Allah, terbiasa dengan adab, dan melihat ibadah sebagai bagian dari kehidupan.',
  },
  {
    title: 'Akademik inti yang bertahap',
    body: 'Literasi, numerasi, sains, bahasa, dan keterampilan berpikir disusun sesuai fase tumbuh anak.',
  },
  {
    title: 'Rutinitas rumah yang mendidik',
    body: 'Jadwal belajar tidak berdiri sendiri, tetapi menyatu dengan ibadah, tanggung jawab rumah, bermain, dan istirahat.',
  },
  {
    title: 'Kolaborasi orang tua dan fasilitator',
    body: 'Orang tua mendapat panduan dan ruang konsultasi agar pendampingan di rumah lebih tenang dan konsisten.',
  },
];

const activePrograms = [
  {
    title: 'Preschool & Kindergarten',
    age: 'Usia 3-6 tahun',
    body: 'Program usia dini untuk menumbuhkan rasa aman, adab, kemandirian, bahasa, motorik, dan cinta belajar dari rumah.',
    points: [
      'Tema belajar sederhana yang dekat dengan kehidupan anak.',
      'Aktivitas bermain bermakna, eksplorasi, cerita, seni, dan rutinitas adab.',
      'Pembiasaan ibadah harian sesuai usia tanpa tekanan berlebihan.',
      'Panduan orang tua untuk mendampingi anak dengan ritme lembut.',
    ],
  },
  {
    title: 'IAIS Elementary School',
    age: 'Usia 6-12 tahun',
    body: 'Program sekolah dasar home-based untuk menguatkan ilmu Islam, akademik inti, tanggung jawab, dan keterampilan hidup anak.',
    points: [
      'Integrasi diniyyah, Quraniyah, literasi, numerasi, sains, bahasa, dan life skills.',
