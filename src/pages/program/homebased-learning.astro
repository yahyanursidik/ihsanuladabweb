const curriculumTracks = [
  {
    title: 'Islamic Essential Knowledge',
    items: ['Aqidah dan tauhid', 'Adab dan akhlak', 'Ibadah harian', 'Sirah Nabawiyah', "Tahsin dan tahfidz Al-Qur'an"],
  },
