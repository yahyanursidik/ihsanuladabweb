const signals = [
  {
    icon: ClipboardCheck,
    step: '01',
    title: 'Petakan kebutuhan',
    body: 'Kenali fase tumbuh, kesiapan anak, dan kapasitas pendampingan keluarga.',
  },
  {
    icon: CalendarCheck,
    step: '02',
    title: 'Susun ritme',
    body: 'Tempatkan ibadah, belajar, bermain, bergerak, dan istirahat secara realistis.',
  },
  {
    icon: Puzzle,
    step: '03',
    title: 'Jalankan aktivitas',
    body: 'Hubungkan materi dengan eksplorasi, proyek, percakapan, dan kehidupan rumah.',
  },
  {
    icon: ChartNoAxesCombined,
    step: '04',
    title: 'Baca perkembangan',
    body: 'Amati pemahaman, adab, kemandirian, kebiasaan, dan kebutuhan tindak lanjut.',
  },
];

const needs = [
  'Anak membutuhkan pendidikan Islam yang terarah, tetapi keluarga membutuhkan ritme belajar yang lebih fleksibel.',
  'Orang tua ingin mendidik dari rumah, namun tetap membutuhkan kurikulum, panduan, dan evaluasi yang jelas.',
  'Keluarga diaspora atau keluarga berpindah tempat membutuhkan sistem belajar yang tetap stabil.',
  'Anak perlu tumbuh dengan adab, rutinitas ibadah, literasi, numerasi, dan keterampilan hidup secara seimbang.',
