  ['Tentang Program', '#tentang-program'],
  ['Untuk Siapa', '#untuk-siapa'],
  ['Kurikulum', '#kurikulum'],
  ['Tahapan', '#tahapan'],
  ['Kontak', '#kontak'],
];

const programMenuItems = [
  {
    label: 'Semua Program',
    href: '/#program',
    note: 'Peta ekosistem belajar',
  },
  {
    label: 'Ihsanul Adab Parenting Academy',
    href: '/iapa/',
    note: 'Parenting Islami keluarga',
  },
  {
    label: 'The Father Project',
    href: '/program/the-father-project/',
    note: 'Komunitas ayah Muslim',
  },
  {
    label: 'The Fitrah Journey',
    href: '/program/the-fitrah-journey/',
    note: 'Ruang tumbuh muslimah',
  },
  {
    label: 'Headmaster & Teacher Academy',
    href: '/program/headmaster-teacher-academy/',
    note: 'Pengembangan guru dan sekolah',
  },
  {
    label: 'PKGQ PAUD & SD',
    href: '/program/kaderisasi-guru-quran-paud-sd/',
    note: 'Kaderisasi guru Al-Qur\'an',
  },
  {
    label: 'IAIEE',
    href: '/program/iaiee/',
    note: 'Konsultasi mutu pendidikan',
  },
  {
    label: 'Ushuluna',
    href: '/program/ushuluna/',
    note: 'Fondasi Islam bertahap',
  },
  {
    label: 'DeenUp',
    href: '/program/deenup/',
    note: 'Pembinaan remaja Muslim',
  },
  {
    label: 'IAIS Home-Based Learning',
    href: '/program/homebased-learning/',
    note: 'Sekolah Islam dari rumah',
  },
];

const stats = [
  ['120+', 'muslimah telah mengikuti pembelajaran'],
  ['2 Semester', 'kelas utama yang bertahap'],
  ['Online', 'belajar dari rumah dengan pendampingan'],
];

const concerns = [
  'Ingin bertumbuh sebagai muslimah, tetapi sering bingung memulai dari mana.',
  'Merasa lelah menjalani banyak peran tanpa cukup ruang untuk menata diri.',
  'Ingin memahami fitrah perempuan tanpa lepas dari tuntunan Islam yang benar.',
  'Butuh komunitas belajar yang menjaga adab, tidak menghakimi, dan tetap terarah.',
];

const audiences = [
  'Muslimah single yang ingin menyiapkan diri sebelum menikah.',
  'Istri yang ingin memperbaiki komunikasi, adab, dan ketenangan rumah.',
  'Ibu muda yang sedang belajar mengasuh sambil menata diri.',
  'Muslimah yang ingin memahami peran sebagai hamba, anak, istri, ibu, dan bagian dari umat.',
  'Muslimah yang membutuhkan ruang belajar yang lembut, aman, dan tetap berpijak pada ilmu.',
];

const pillars = [
  {
    title: 'Tauhid dan adab muslimah',
    body: 'Menguatkan orientasi hidup sebagai hamba Allah sebelum membahas peran sosial dan keluarga.',
  },
  {
    title: 'Mengenal diri dan fitrah',
    body: 'Membantu peserta membaca kebutuhan diri, emosi, batasan, dan potensi dengan bahasa yang jernih.',
  },
  {
    title: 'Peran dalam keluarga',
    body: 'Membahas adab sebagai anak, persiapan pernikahan, komunikasi suami-istri, dan peran ibu.',
  },
  {
    title: 'Keseharian yang lebih tertata',
    body: 'Menghubungkan ilmu dengan rutinitas ibadah, rumah, kesehatan diri, produktivitas, dan amal harian.',
  },
];

const formats = [
  {
    title: 'Webinar dan short course',
    body: 'Kelas tematik ringan untuk membuka wawasan, memperbaiki cara pandang, dan mulai mempraktikkan langkah kecil.',
  },
  {
    title: 'Fitrah Class Program',
    body: 'Program utama dua semester dengan materi bertahap, refleksi, tugas penerapan, dan pendampingan.',
  },
  {
    title: 'Komunitas dan mentoring',
    body: 'Ruang belajar bersama yang dipandu agar interaksi tetap beradab, suportif, dan tidak melebar tanpa arah.',
  },
];

const stages = [
  ['Orientasi', 'Mengenali tujuan belajar, adab kelas, ritme program, dan kebutuhan pribadi peserta.'],
  ['Penguatan fondasi', 'Mempelajari tauhid, adab, fitrah, dan cara menata hati sebelum memperbaiki peran.'],
  ['Pendalaman peran', 'Membahas peran muslimah dalam keluarga, relasi, pengasuhan, komunikasi, dan keseharian.'],
  ['Refleksi dan praktik', 'Menyusun langkah perbaikan kecil yang bisa dijaga setelah program selesai.'],
];

const guardrails = [
  'Materi diarahkan agar selaras dengan Al-Qur\'an, Sunnah, dan pemahaman salafus shalih.',
  'Pembahasan psikologis diposisikan sebagai pendukung, bukan pengganti bimbingan agama.',
  'Komunitas dijaga dari cerita yang membuka aib tanpa kebutuhan dan dari nasihat yang melampaui kapasitas.',
  'Visual dan media belajar dipilih dengan kehati-hatian, tanpa figur makhluk bernyawa.',
];
---

<BaseLayout
  title="The Fitrah Journey - Yayasan Pendidikan Ihsanul Adab"
  description="The Fitrah Journey adalah program edukasi dan komunitas muslimah dewasa untuk menata diri, memahami peran, dan bertumbuh kembali kepada fitrah dengan bimbingan Islam."
>
  <a class="skip-link" href="#konten">Lewati ke konten utama</a>

  <header class="site-header fitrah-site-header">
    <div class="topbar fitrah-topbar">
      <span>Ruang belajar muslimah untuk menata diri, peran, dan fitrah.</span>
      <a href={consultationUrl}>Konsultasi program</a>
    </div>

    <div class="nav-shell">
      <a class="brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="58" height="58" />
        <span>
          <strong>Ihsanul Adab</strong>
          <small>The Fitrah Journey</small>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Navigasi The Fitrah Journey">
        <a href="/">Beranda</a>
        <a href="/tentang-kami/">Tentang Kami</a>
        <a href="/karir-pengabdian/">Karir & Pengabdian</a>
        <details class="nav-dropdown">
          <summary>Program</summary>
          <div class="nav-program-panel">
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </details>
        {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>

      <a class="nav-cta fitrah-nav-cta" href={lmsUrl}>Akses LMS IA</a>

      <details class="mobile-menu">
        <summary aria-label="Buka menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-panel">
          <a href="/">Beranda</a>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <div class="mobile-program-group">
            <strong>Program</strong>
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
          <a href="#tentang-program">Tentang Program</a>
          <a href="#untuk-siapa">Untuk Siapa</a>
          <a href="#kurikulum">Kurikulum</a>
          <a href="#tahapan">Tahapan</a>
          <a class="button primary" href={consultationUrl}>Konsultasi Program</a>
        </div>
      </details>
    </div>
  </header>

  <main id="konten">
    <section class="fitrah-hero" aria-labelledby="fitrah-title">
      <img
        src="/images/fitrah-journey-muslimah-hero.png"
        alt="Sudut belajar muslimah dengan mushaf tertutup, jurnal, buku, kain plum, lampu hangat, dan pola geometri Islami tanpa figur makhluk bernyawa"
      />
      <div class="fitrah-hero-content">
        <p class="eyebrow">Pulih dalam iman, tumbuh dalam peran</p>
        <h1 id="fitrah-title">The Fitrah Journey</h1>
        <p>
          Program edukasi dan komunitas untuk muslimah dewasa yang ingin menata diri,
          memahami peran, dan kembali bertumbuh dengan bimbingan Islam.
        </p>
        <blockquote>
          Perjalanan kembali kepada fitrah tidak selalu dimulai dari langkah besar.
          Kadang ia dimulai dari belajar jujur, memperbaiki niat, dan mengambil satu
          amal kecil yang bisa dijaga.
        </blockquote>
        <div class="hero-actions">
          <a class="button primary" href={consultationUrl}>Konsultasi Program</a>
          <a class="button secondary" href="#tentang-program">Pelajari Program</a>
        </div>
      </div>
    </section>

    <section class="fitrah-stats" aria-label="Ringkasan The Fitrah Journey">
      {stats.map(([value, label]) => (
        <article>
          <strong>{value}</strong>
          <span>{label}</span>
        </article>
      ))}
    </section>

    <section class="section fitrah-intro" id="tentang-program">
      <div>
        <p class="eyebrow">Tentang Program</p>
        <h2>Ruang belajar yang lembut, terarah, dan tetap berpijak pada ilmu.</h2>
      </div>
      <div class="stack">
        <p>
          The Fitrah Journey membantu muslimah dewasa memahami dirinya sebagai hamba Allah,
          lalu menata peran sebagai anak, istri, ibu, dan bagian dari masyarakat dengan
          lebih sadar dan beradab.
        </p>
        <p>
          Program ini tidak menjanjikan perubahan instan. Peserta diajak belajar bertahap,
          melakukan refleksi yang terjaga, dan menyusun langkah kecil yang realistis untuk
          hidup sehari-hari.
        </p>
      </div>
    </section>

    <section class="section fitrah-concerns">
      <div class="section-heading compact">
        <p class="eyebrow">Kebutuhan yang dijawab</p>
        <h2>Untuk muslimah yang ingin pulang kepada arah yang lebih tenang dan jelas.</h2>
      </div>
      <div class="fitrah-concern-grid">
        {concerns.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section fitrah-audience" id="untuk-siapa">
      <div>
        <p class="eyebrow">Siapa yang cocok bergabung?</p>
        <h2>Untuk akhwat dan muslimah dewasa yang ingin belajar menata diri tanpa kehilangan kelembutan.</h2>
      </div>
      <ul class="check-list fitrah-check-list">
        {audiences.map((audience) => <li>{audience}</li>)}
      </ul>
    </section>

    <section class="section fitrah-pillars" id="kurikulum">
      <div class="section-heading">
        <p class="eyebrow">Pilar pembelajaran</p>
        <h2>Materi disusun agar peserta memahami prinsip, peran, dan langkah amal.</h2>
      </div>
      <div class="fitrah-pillar-grid">
        {pillars.map((pillar) => (
          <article>
            <h3>{pillar.title}</h3>
            <p>{pillar.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="fitrah-importance">
      <div>
        <p class="eyebrow">Adab dan batasan program</p>
        <h2>Bertumbuh dengan empati, tetapi tetap menjaga arah syar'i.</h2>
      </div>
      <div>
        {guardrails.map((item) => <p>{item}</p>)}
      </div>
    </section>

    <section class="section fitrah-benefits">
      <div class="section-heading">
        <p class="eyebrow">Format Program</p>
        <h2>Pilih pintu masuk sesuai kesiapan dan kebutuhan belajar.</h2>
      </div>
      <div class="fitrah-benefit-grid">
        {formats.map((format) => (
          <article>
            <h3>{format.title}</h3>
            <p>{format.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section fitrah-stages" id="tahapan">
      <div class="section-heading compact">
        <p class="eyebrow">Tahapan Program</p>
        <h2>Perjalanan dibuat bertahap agar peserta tidak merasa harus berubah sekaligus.</h2>
      </div>
      <div class="fitrah-stage-grid">
        {stages.map(([title, detail], index) => (
          <article>
            <span>{index + 1}</span>
            <h3>{title}</h3>
            <p>{detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section fitrah-closing">
      <article>
        <p class="eyebrow">The Fitrah Journey</p>
        <h2>Pulih dalam iman, tumbuh dalam peran, kembali kepada fitrah.</h2>
        <p>
          Program ini menjadi bagian dari ikhtiar Ihsanul Adab dalam menghadirkan ruang
          edukasi muslimah yang lembut, beradab, dan terarah.
        </p>
      </article>
      <article>
        <p class="eyebrow">Masih ingin bertanya?</p>
        <h2>Konsultasikan kebutuhan belajar Anda dengan admin.</h2>
        <p>Kami siap membantu menjelaskan format kelas, alur program, jadwal, dan langkah awal bergabung.</p>
        <a class="button primary" href={whatsappUrl}>WhatsApp Admin</a>
      </article>
    </section>

    <section class="cta fitrah-cta" id="kontak">
      <div>
        <p class="eyebrow">Mulai dari langkah kecil yang bisa dijaga</p>
        <h2>Siap menata perjalanan bersama The Fitrah Journey?</h2>
        <p>
          Ceritakan kebutuhan Anda kepada admin agar kami bisa membantu memilih kelas,
          format belajar, dan langkah awal yang paling sesuai.
        </p>
      </div>
      <div class="cta-actions">
        <a class="button primary" href={consultationUrl}>Konsultasi Program</a>
        <a class="button secondary" href={whatsappUrl}>WhatsApp Admin</a>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-brand">
      <img src="/images/logo-ihsanul-adab.png" alt="" width="44" height="44" />
      <div>
        <p>Yayasan Pendidikan Ihsanul Adab</p>
        <span>Mendidik dengan adab. Menumbuhkan dengan ilmu. Mengokohkan dengan amal.</span>
      </div>
    </div>
    <nav aria-label="Navigasi footer The Fitrah Journey">
      {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  </footer>

  <a class="floating-help" href={consultationUrl}>Konsultasi</a>
</BaseLayout>
