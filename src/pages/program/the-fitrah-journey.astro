const audiences = [
  'Ibu rumah tangga yang ingin menguatkan peran.',
  'Muslimah single yang ingin persiapan sebelum menikah.',
  'Istri yang merasa lelah atau kehilangan arah.',
  'Ibu muda yang sedang berjuang membesarkan anak.',
