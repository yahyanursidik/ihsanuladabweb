---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  ArrowDown,
  ArrowRight,
  BriefcaseBusiness,
  ChartNoAxesCombined,
  Check,
  CircleCheck,
  ClipboardCheck,
  Compass,
  ExternalLink,
  GraduationCap,
  HandHeart,
  House,
  Lightbulb,
  Menu,
  MessageCircle,
  Network,
  NotebookPen,
  Presentation,
  Route,
  School,
  ShieldCheck,
  Target,
  UsersRound,
  Waypoints,
} from '@lucide/astro';
import '../../styles/headmaster-teacher-academy-redesign.css';

const navItems = [
  ['Beranda', '/'],
  ['Tentang Kami', '/tentang-kami/'],
  ['Karir & Pengabdian', '/karir-pengabdian/'],
  ['Tentang HTA', '#tentang-hta'],
  ['Alur Belajar', '#alur-belajar'],
  ['Program', '#program-hta'],
  ['Peserta', '#untuk-siapa'],
  ['Kontak', '#kontak'],
];

const programMenuItems = [
  {
    label: 'Semua Program',
    href: '/#program',
    note: 'Ikhtisar layanan',
  },
  {
    label: 'Ihsanul Adab Parenting Academy',
    href: '/iapa/',
    note: 'Parenting Islami keluarga',
  },
  {
    label: 'The Father Project',
    href: '/program/the-father-project/',
    note: 'Komunitas ayah Muslim',
  },
  {
    label: 'The Fitrah Journey',
    href: '/program/the-fitrah-journey/',
    note: 'Fitrah muslimah dewasa',
  },
  {
    label: 'Headmaster & Teacher Academy',
    href: '/program/headmaster-teacher-academy/',
    note: 'Pengembangan guru dan sekolah',
  },
  {
    label: 'PKGQ PAUD & SD',
    href: '/program/kaderisasi-guru-quran-paud-sd/',
    note: 'Kaderisasi guru Al-Quran',
  },
  {
    label: 'IAIEE',
    href: '/program/iaiee/',
    note: 'Konsultasi mutu pendidikan',
  },
  {
    label: 'Ushuluna',
    href: '/program/ushuluna/',
    note: 'Fondasi Islam bertahap',
  },
  {
    label: 'Ihsanul Adab Quran Academy',
    href: '/#program',
    note: 'Pembelajaran Al-Quran keluarga',
  },
  {
    label: 'DeenUp',
    href: '/program/deenup/',
    note: 'Pembinaan remaja Muslim',
  },
  {
    label: 'IAIS Home-Based Learning',
    href: '/program/homebased-learning/',
    note: 'Sekolah Islam dari rumah',
  },
];

const realities = [
  'Guru ingin kelas lebih hidup, tetapi sering tersita administrasi dan masalah perilaku murid.',
  'Kepala sekolah diminta memimpin mutu, SDM, orang tua, dan budaya sekolah dalam waktu bersamaan.',
  'Banyak pelatihan terasa umum, sementara masalah sekolah Islam membutuhkan arah tauhid, adab, dan langkah praktis.',
];

const foundations = [
  {
    icon: Compass,
    title: 'Tauhid sebagai arah',
    body: 'Setiap kebijakan, kelas, dan keputusan sekolah diarahkan sebagai amanah ibadah.',
  },
  {
    icon: HandHeart,
    title: 'Adab sebagai budaya',
    body: 'Pendidik dibina untuk menghadirkan ilmu dengan hikmah, keteladanan, dan komunikasi yang menjaga kehormatan.',
  },
  {
    icon: ChartNoAxesCombined,
    title: 'Mutu sebagai ikhtiar',
    body: 'Perbaikan sekolah dilakukan bertahap melalui standar, ritme kerja, supervisi, dan evaluasi yang realistis.',
  },
];

const goals = [
  'Menguatkan identitas pendidik Muslim: lurus niat, jelas peran, dan matang dalam adab profesional.',
  'Membantu kepala sekolah membaca masalah lembaga, menentukan prioritas, dan menggerakkan tim dengan hikmah.',
  'Menerjemahkan nilai Islam menjadi budaya kelas, budaya kerja, layanan orang tua, dan standar mutu sekolah.',
  'Membangun komunitas belajar pendidik yang saling menasihati, berbagi praktik baik, dan bertumbuh bersama.',
];

const mainPrograms = [
  {
    icon: Presentation,
    title: 'Majelis Webinar Pendidik',
    label: 'Terbuka berkala',
    summary:
      'Sesi tematik untuk membaca masalah nyata sekolah Islam: kepemimpinan, budaya adab, komunikasi orang tua, kelas, dan mutu pembelajaran.',
    fit: 'Cocok sebagai pintu masuk bagi guru, kepala sekolah, pengelola, yayasan, dan calon pendidik.',
  },
  {
    icon: ClipboardCheck,
    title: 'Workshop Solusi Sekolah',
    label: 'Praktis',
    summary:
      'Kelas kerja berbasis kasus untuk menyusun perangkat, alur supervisi, peta masalah, dan langkah perbaikan yang bisa langsung dicoba.',
    fit: 'Cocok untuk tim yang membutuhkan solusi terarah tanpa kehilangan ruh Islam.',
  },
  {
    icon: Network,
    title: 'School Leadership Circle',
    label: 'Kepala sekolah',
    summary:
      'Pembinaan untuk kepala sekolah dan wakil kepala sekolah agar lebih tenang membaca data, memimpin guru, menjaga budaya, dan mengambil keputusan.',
    fit: 'Cocok untuk pimpinan sekolah Islam dan calon pemimpin pendidikan.',
  },
  {
    icon: GraduationCap,
    title: 'Teacher Growth Program',
    label: 'Guru & calon guru',
    summary:
      'Penguatan kompetensi mengajar, adab pendidik, manajemen kelas, komunikasi, asesmen, dan kesiapan mental menjadi guru Muslim.',
    fit: 'Cocok untuk guru aktif, calon guru, dan lembaga yang membina tim pengajar.',
  },
  {
    icon: UsersRound,
    title: 'Komunitas Kepala Sekolah & Guru Belajar',
    label: 'Komunitas',
    summary:
      'Ruang ukhuwah profesi untuk bertanya, berbagi pengalaman lapangan, menjaga semangat, dan menumbuhkan kebiasaan belajar yang berkelanjutan.',
    fit: 'Cocok untuk pendidik yang tidak ingin berjalan sendiri.',
  },
];

const differences = [
  'Berbasis Al-Quran dan Sunnah dengan pemahaman Salafus Shalih.',
  'Bahasa pembelajaran dewasa: jelas, ringkas, dan menghargai pengalaman lapangan.',
  'Membahas kasus nyata sekolah, bukan teori yang jauh dari kelas.',
  'Menghubungkan adab, pedagogik, kepemimpinan, dan sistem mutu.',
  'Menghasilkan alat kerja: checklist, rubrik, peta masalah, dan rencana tindak lanjut.',
  'Tidak menggurui, tetapi membersamai pendidik yang sedang berjuang.',
];

const audiences = [
  'Guru PAUD, SD, SMP, dan SMA Islam yang ingin mengajar lebih terarah dan beradab.',
  'Kepala sekolah, wakil kepala sekolah, koordinator jenjang, dan koordinator kurikulum.',
  'Pengelola yayasan pendidikan yang ingin menata mutu tanpa kehilangan ruh tarbiyah.',
  'Calon guru dan calon pemimpin sekolah yang ingin dibina sejak awal.',
  'Lembaga yang ingin membangun budaya kerja Islami, tertib, dan berkelanjutan.',
];

const webinarTopics = [
  'Kepemimpinan sekolah Islam yang menenangkan tim dan menjaga arah.',
  'Supervisi guru yang membina, bukan sekadar menilai.',
  'Manajemen kelas, adab murid, dan komunikasi dengan orang tua.',
  'Kurikulum, asesmen, budaya sekolah, dan mutu layanan pendidikan.',
];

const heroMetrics = [
  { icon: UsersRound, label: 'Komunitas', value: 'kepala sekolah dan guru' },
  { icon: BriefcaseBusiness, label: 'Aplikatif', value: 'berbasis problem lapangan' },
  { icon: Route, label: 'Bertahap', value: 'dari webinar ke pendampingan' },
];

const learningFlow = [
  {
    icon: Compass,
    title: 'Refleksi Amanah',
    body: 'Menata niat, membaca peran, dan memahami masalah pendidikan sebagai amanah yang perlu ditunaikan dengan ilmu.',
  },
  {
    icon: Target,
    title: 'Peta Masalah',
    body: 'Membedakan gejala dan akar masalah pada kelas, guru, orang tua, budaya sekolah, dan kepemimpinan lembaga.',
  },
  {
    icon: NotebookPen,
    title: 'Praktik Terarah',
    body: 'Menyusun langkah kecil: instrumen kerja, SOP ringan, rubrik, agenda supervisi, atau rencana tindak lanjut.',
  },
  {
    icon: UsersRound,
    title: 'Komunitas Bertumbuh',
    body: 'Menjaga proses melalui forum belajar, nasihat, studi kasus, dan pertemuan berkala bersama para pendidik.',
  },
];

const whatsappUrl = 'https://wa.me/6285179676003';
const consultUrl = 'https://berbagi.link/ypihsanuladab';
const lmsUrl = 'https://hub.ihsanuladab.or.id/';
---

<BaseLayout
  title="Headmaster & Teacher Academy (HTA) - Yayasan Pendidikan Ihsanul Adab"
  description="HTA adalah pusat pembinaan guru dan pemimpin sekolah Islam berbasis tauhid, adab, dan profesionalisme."
>
  <div class="hm-hta">
  <a class="skip-link hm-hta-skip" href="#konten">Lewati ke konten utama</a>

  <header class="site-header hm-hta-header">
    <div class="topbar">
      <div class="topbar-inner">
        <span>Pengembangan guru dan pemimpin sekolah Islam</span>
        <a href={whatsappUrl}>
          Konsultasi HTA
          <ArrowRight size={15} strokeWidth={1.8} aria-hidden="true" />
        </a>
      </div>
    </div>

    <div class="nav-shell">
      <a class="brand" href="/" aria-label="Yayasan Pendidikan Ihsanul Adab">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="58" height="58" />
        <span>
          <strong>HTA</strong>
          <small>Headmaster & Teacher Academy</small>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Navigasi Headmaster & Teacher Academy">
        <a href="/">Beranda</a>
        <details class="nav-dropdown">
          <summary aria-label="Buka daftar program">Program</summary>
          <div class="nav-program-panel">
            {programMenuItems.map((item) => (
              <a
                href={item.href}
                aria-current={item.href === '/program/headmaster-teacher-academy/' ? 'page' : undefined}
              >
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </details>
        <a href="#tentang-hta" data-section-link="tentang-hta">Tentang</a>
        <a href="#alur-belajar" data-section-link="alur-belajar">Alur</a>
        <a href="#program-hta" data-section-link="program-hta">Program HTA</a>
        <a href="#untuk-siapa" data-section-link="untuk-siapa">Peserta</a>
      </nav>

      <a class="nav-cta" href={lmsUrl}>
        Akses LMS
        <ExternalLink size={15} strokeWidth={1.8} aria-hidden="true" />
      </a>

      <details class="mobile-menu">
        <summary aria-label="Buka menu">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <div class="mobile-panel">
          <a href="/">Beranda</a>
          <a href="/tentang-kami/">Tentang Kami</a>
          <a href="/karir-pengabdian/">Karir & Pengabdian</a>
          <div class="mobile-program-group">
            <strong>Program</strong>
            {programMenuItems.map((item) => (
              <a href={item.href}>
                <span>{item.label}</span>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
          {navItems.slice(3).map(([label, href]) => <a href={href}>{label}</a>)}
          <a class="button primary" href={lmsUrl}>
            Akses LMS
            <ExternalLink size={17} strokeWidth={1.8} aria-hidden="true" />
          </a>
        </div>
      </details>
    </div>
    <div class="page-progress" aria-hidden="true"><span></span></div>
  </header>

  <main id="konten">
    <section class="hta-hero" aria-labelledby="hta-title">
      <img
        src="/images/hta-faceless-teacher-classroom-hero.png"
        alt="Guru ikhwan dan peserta kelas tampak dari belakang saat mempelajari diagram pengembangan sekolah"
        width="1674"
        height="936"
        fetchpriority="high"
      />
      <div class="hta-hero-shade" aria-hidden="true"></div>
      <div class="hta-hero-content">
        <p class="eyebrow">Headmaster & Teacher Academy</p>
        <h1 id="hta-title">Menata kepemimpinan. Menguatkan guru. Menumbuhkan mutu.</h1>
        <p>
          HTA membantu kepala sekolah dan guru Muslim membaca persoalan lembaga,
          memperbaiki praktik kelas, serta membangun budaya kerja yang beradab
          melalui pembinaan yang bertahap dan dekat dengan realitas lapangan.
        </p>
        <div class="hero-signals" aria-label="Ringkasan Headmaster and Teacher Academy">
          <span><UsersRound size={16} strokeWidth={1.8} aria-hidden="true" />Guru & pimpinan</span>
          <span><BriefcaseBusiness size={16} strokeWidth={1.8} aria-hidden="true" />Berbasis kasus</span>
          <span><Route size={16} strokeWidth={1.8} aria-hidden="true" />Bertahap</span>
        </div>
        <div class="hero-actions">
          <a class="button primary" href={consultUrl}>
            Konsultasi program
            <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
          </a>
          <a class="button secondary" href="#alur-belajar">
            Lihat alur HTA
            <ArrowDown size={18} strokeWidth={1.8} aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    <section class="hta-hero-metrics" aria-label="Ringkasan Headmaster & Teacher Academy">
      {heroMetrics.map(({ icon: Icon, label, value }) => (
        <div>
          <Icon size={22} strokeWidth={1.6} aria-hidden="true" />
          <strong>{label}</strong>
          <span>{value}</span>
        </div>
      ))}
    </section>

    <section class="section hta-welcome" id="tentang-hta">
      <div>
        <p class="eyebrow">Titik berangkat</p>
        <h2>Di balik sekolah Islam yang kuat, selalu ada guru yang beradab dan kepala sekolah yang memimpin dengan hikmah.</h2>
      </div>
      <div class="stack">
        <p>
          Realitanya, banyak guru dan kepala sekolah bekerja keras, menghadapi problem
          manajemen, SDM, kelas, dan orang tua, tetapi belum memiliki ruang belajar yang
          relevan, praktis, dan sesuai nilai Islam.
        </p>
        <p>
          Headmaster & Teacher Academy hadir sebagai jawaban: bukan sekadar pelatihan,
          tetapi ruang tumbuh bersama bagi pendidik dan pemimpin sekolah Islam yang
          ingin memperbaiki diri, tim, kelas, dan lembaga secara bertahap.
        </p>
        <div class="hta-reality-list">
          {realities.map((item, index) => (
            <span>
              <small>{String(index + 1).padStart(2, '0')}</small>
              <span>{item}</span>
            </span>
          ))}
        </div>
      </div>
    </section>

    <section class="section hta-about">
      <div>
        <p class="eyebrow">Apa itu HTA?</p>
        <h2>Program pengembangan guru, kepala sekolah, dan lembaga pendidikan Islam.</h2>
      </div>
      <div class="stack">
        <p>
          HTA diselenggarakan oleh Yayasan Pendidikan Ihsanul Adab untuk memperkuat
          kepemimpinan pendidikan Islam, meningkatkan kompetensi keguruan dan manajemen
          sekolah, serta menumbuhkan komunitas belajar yang sehat bagi para pendidik.
        </p>
        <div class="hta-foundation">
          {foundations.map(({ icon: Icon, title, body }) => (
            <article>
              <Icon size={27} strokeWidth={1.55} aria-hidden="true" />
              <strong>{title}</strong>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section hta-goals">
      <div class="section-heading">
        <p class="eyebrow">Tujuan Headmaster & Teacher Academy</p>
        <h2>HTA bertujuan membangun mutu pendidikan Islam secara bertahap dan berkelanjutan.</h2>
      </div>
      <div class="hta-goal-grid">
        {goals.map((goal, index) => (
          <article>
            <div>
              <Target size={22} strokeWidth={1.6} aria-hidden="true" />
              <span>{String(index + 1).padStart(2, '0')}</span>
            </div>
            <p>{goal}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section hta-flow" id="alur-belajar">
      <div class="section-heading">
        <p class="eyebrow">Alur belajar HTA</p>
        <h2>Dari refleksi amanah menuju perbaikan yang dapat dijaga bersama.</h2>
      </div>
      <ol class="hta-flow-grid" aria-label="Alur belajar Headmaster and Teacher Academy">
        {learningFlow.map(({ icon: Icon, ...step }, index) => (
          <li style={'--flow-order: ' + index}>
            <div>
              <Icon size={25} strokeWidth={1.6} aria-hidden="true" />
              <small>{String(index + 1).padStart(2, '0')}</small>
            </div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
            {index < learningFlow.length - 1 && <ArrowRight class="hta-flow-arrow" size={23} strokeWidth={1.6} aria-hidden="true" />}
          </li>
        ))}
      </ol>
    </section>

    <section class="section hta-programs" id="program-hta">
      <div class="section-heading">
        <p class="eyebrow">Program Utama HTA</p>
        <h2>Ruang belajar praktis untuk pendidik, kepala sekolah, pengelola, dan calon pemimpin pendidikan.</h2>
      </div>
      <div class="hta-program-grid">
        {mainPrograms.map(({ icon: Icon, ...program }, index) => (
          <article>
            <div class="program-meta">
              <Icon size={25} strokeWidth={1.55} aria-hidden="true" />
              <p>{program.label}</p>
              <small>{String(index + 1).padStart(2, '0')}</small>
            </div>
            <h3>{program.title}</h3>
            <p>{program.summary}</p>
            <span>{program.fit}</span>
            <a href={consultUrl}>
              Tanyakan program
              <ArrowRight size={17} strokeWidth={1.8} aria-hidden="true" />
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="hta-difference" id="keunggulan">
      <div>
        <p class="eyebrow">Prinsip yang dijaga</p>
        <h2>Praktis untuk lapangan, tetap berhati-hati dalam arah pendidikan.</h2>
      </div>
      <div class="hta-difference-grid">
        {differences.map((item) => (
          <span>
            <ShieldCheck size={21} strokeWidth={1.7} aria-hidden="true" />
            <span>{item}</span>
          </span>
        ))}
      </div>
    </section>

    <section class="section hta-audience" id="untuk-siapa">
      <div>
        <p class="eyebrow">Peserta HTA</p>
        <h2>Untuk mereka yang memikul amanah pendidikan dan ingin terus bertumbuh.</h2>
      </div>
      <ul class="check-list">
        {audiences.map((audience) => (
          <li>
            <CircleCheck size={21} strokeWidth={1.7} aria-hidden="true" />
            <span>{audience}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="section hta-webinar">
      <article>
        <Presentation size={34} strokeWidth={1.45} aria-hidden="true" />
        <p class="eyebrow">Langkah pertama tidak harus besar</p>
        <h2>Mulailah dari majelis webinar HTA.</h2>
        <p>Webinar Headmaster & Teacher Academy membahas topik yang dekat dengan kebutuhan sekolah Islam dan mudah ditindaklanjuti.</p>
        <ul>
          {webinarTopics.map((topic) => (
            <li>
              <Check size={17} strokeWidth={2} aria-hidden="true" />
              <span>{topic}</span>
            </li>
          ))}
        </ul>
      </article>
      <article>
        <Lightbulb size={34} strokeWidth={1.45} aria-hidden="true" />
        <p class="eyebrow">Mulai langkah kecil Anda sekarang</p>
        <h2>Tentukan titik perbaikan yang paling mendesak.</h2>
        <p>Ceritakan kebutuhan guru, kepala sekolah, atau lembaga Anda. Admin akan membantu menjelaskan program yang paling relevan.</p>
        <div class="hta-contact-lines">
          <a href="mailto:salam@ihsanuladab.or.id">salam@ihsanuladab.or.id</a>
          <a href={whatsappUrl}>+62 851-7967-6003</a>
        </div>
        <a class="button primary" href={consultUrl}>
          Konsultasi HTA
          <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
        </a>
      </article>
    </section>

    <section class="cta hta-cta" id="kontak">
      <div>
        <p class="eyebrow">Pendidikan adalah amal panjang</p>
        <h2>HTA hadir untuk menemani para pendidik agar tidak berjalan sendiri.</h2>
        <p>
          Bersama kita bangun pendidikan Islam yang bermutu, beradab, dan berdampak,
          dengan niat, arah, dan perjuangan yang tetap lurus.
        </p>
      </div>
      <div class="cta-actions">
        <a class="button primary" href={consultUrl}>
          Konsultasi program
          <ArrowRight size={18} strokeWidth={1.8} aria-hidden="true" />
        </a>
        <a class="button secondary" href={whatsappUrl}>
          WhatsApp admin
          <MessageCircle size={18} strokeWidth={1.8} aria-hidden="true" />
        </a>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-statement">
      <div>
        <p class="eyebrow">Headmaster & Teacher Academy</p>
        <h2>Guru bertumbuh. Pemimpin lebih jernih. Sekolah bergerak dengan arah.</h2>
      </div>
      <School size={44} strokeWidth={1.3} aria-hidden="true" />
    </div>
    <div class="footer-meta">
      <a class="footer-brand" href="/">
        <img src="/images/logo-ihsanul-adab.png" alt="" width="44" height="44" />
        <div>
          <p>Yayasan Pendidikan Ihsanul Adab</p>
          <span>Mendidik dengan adab. Menumbuhkan dengan ilmu.</span>
        </div>
      </a>
      <nav aria-label="Navigasi footer HTA">
        {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
      </nav>
      <div>
        <a href={lmsUrl}>Akses LMS</a>
        <span>&copy; 2026 Ihsanul Adab</span>
      </div>
    </div>
  </footer>

  <nav class="hm-mobile-bottom-nav hm-hta-bottom-nav" aria-label="Navigasi bawah HTA">
    <a href="/">
      <House size={20} strokeWidth={1.8} aria-hidden="true" />
      <span>Beranda</span>
    </a>
    <a href="#alur-belajar" data-section-link="alur-belajar">
      <Waypoints size={20} strokeWidth={1.8} aria-hidden="true" />
      <span>Alur</span>
    </a>
    <a href="#program-hta" data-section-link="program-hta">
      <GraduationCap size={20} strokeWidth={1.8} aria-hidden="true" />
      <span>Program</span>
    </a>
    <a href={whatsappUrl}>
      <MessageCircle size={20} strokeWidth={1.8} aria-hidden="true" />
      <span>Tanya</span>
    </a>
    <details>
      <summary>
        <Menu size={20} strokeWidth={1.8} aria-hidden="true" />
        <span>Menu</span>
      </summary>
      <div>
        <a href="/tentang-kami/">Tentang Kami</a>
        <a href="/karir-pengabdian/">Karir & Pengabdian</a>
        <a href="/#program">Semua Program</a>
        <a href={lmsUrl}>Akses LMS</a>
      </div>
    </details>
  </nav>

  <script>
    const htaRevealTargets = document.querySelectorAll(
      '.hm-hta main section > div, .hm-hta main section > ol, .hm-hta main section > ul, .hm-hta main article',
    );
    const htaReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    htaRevealTargets.forEach((item) => item.classList.add('hm-hta-reveal'));

    if (htaReduceMotion || !('IntersectionObserver' in window)) {
      htaRevealTargets.forEach((item) => item.classList.add('is-visible'));
    } else {
      const htaObserver = new IntersectionObserver(
        (entries, currentObserver) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            currentObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.1 },
      );

      htaRevealTargets.forEach((item) => htaObserver.observe(item));
    }

    const htaHeader = document.querySelector('.hm-hta-header');
    const htaProgress = document.querySelector('.hm-hta .page-progress span');
    const htaSectionLinks = [...document.querySelectorAll('.hm-hta [data-section-link]')];
    const htaSections = htaSectionLinks
      .map((link) => document.getElementById(link.getAttribute('data-section-link') || ''))
      .filter((section, index, collection) => section && collection.indexOf(section) === index);
    const htaDetails = [...document.querySelectorAll('.hm-hta .nav-dropdown, .hm-hta .hm-hta-bottom-nav details')];

    const syncHtaNavigation = () => {
      const scrollRange = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollRange > 0 ? Math.min(window.scrollY / scrollRange, 1) : 0;
      htaProgress?.style.setProperty('transform', `scaleX(${progress})`);
      htaHeader?.classList.toggle('is-scrolled', window.scrollY > 16);

      const marker = Math.max(
        (htaHeader?.getBoundingClientRect().height || 0) + 32,
        window.innerHeight * 0.4,
      );
      let activeId = '';
      htaSections.forEach((section) => {
        if (section.getBoundingClientRect().top <= marker) activeId = section.id;
      });

      htaSectionLinks.forEach((link) => {
        const isActive = link.getAttribute('data-section-link') === activeId;
        link.classList.toggle('is-active', isActive);
        if (isActive) link.setAttribute('aria-current', 'location');
        else link.removeAttribute('aria-current');
      });
    };

    htaDetails.forEach((detail) => {
      detail.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => detail.removeAttribute('open'));
      });
    });

    document.addEventListener('click', (event) => {
      htaDetails.forEach((detail) => {
        if (!detail.contains(event.target)) detail.removeAttribute('open');
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      htaDetails.forEach((detail) => detail.removeAttribute('open'));
    });

    window.addEventListener('scroll', syncHtaNavigation, { passive: true });
    window.addEventListener('resize', syncHtaNavigation);
    document.fonts?.ready.then(syncHtaNavigation);
    syncHtaNavigation();
  </script>
  </div>
</BaseLayout>
