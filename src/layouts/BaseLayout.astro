---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Yayasan Pendidikan Ihsanul Adab',
  description = 'Menghidupkan adab, menumbuhkan ilmu, dan mengokohkan generasi melalui layanan pendidikan Islam untuk anak, keluarga, dan masyarakat.',
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#087765" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/logo-ihsanul-adab.png" />
    <link rel="icon" type="image/png" href="/images/logo-ihsanul-adab.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const openMenuSelector = '.site-header details[open], .hm-masthead details[open], .hm-mobile-bottom-nav details[open]';
      const menuAreaSelector = '.site-header, .hm-masthead, .hm-mobile-bottom-nav';

      const closeSiblingMenus = (activeDetails) => {
        document.querySelectorAll(openMenuSelector).forEach((details) => {
          if (details !== activeDetails) details.removeAttribute('open');
        });
      };

      document.addEventListener('toggle', (event) => {
        const target = event.target;
        if (
          target instanceof HTMLDetailsElement &&
          target.open &&
          target.closest(menuAreaSelector)
        ) {
          closeSiblingMenus(target);
        }
      }, true);

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        if (target.closest('.site-header a, .hm-masthead a, .hm-mobile-bottom-nav a')) {
          document.querySelectorAll(openMenuSelector).forEach((details) => {
            details.removeAttribute('open');
          });
          return;
        }

        if (target.closest('.site-header details, .hm-masthead details, .hm-mobile-bottom-nav details')) return;

        document.querySelectorAll(openMenuSelector).forEach((details) => {
          details.removeAttribute('open');
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;

        document.querySelectorAll(openMenuSelector).forEach((details) => {
          details.removeAttribute('open');
        });
      });
    </script>
  </body>
</html>
