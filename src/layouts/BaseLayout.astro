---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Yayasan Pendidikan Ihsanul Adab',
  description = 'Menghidupkan adab, menumbuhkan ilmu, dan mengokohkan generasi melalui layanan pendidikan Islam untuk anak, keluarga, dan masyarakat.',
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#087765" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/logo-ihsanul-adab.png" />
    <link rel="icon" type="image/png" href="/images/logo-ihsanul-adab.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
